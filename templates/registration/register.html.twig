{% extends 'auth_base.html.twig' %}

{% block title %}{{ 'auth.register.heading'|trans }}{% endblock %}

{% block body %}
<div class="auth-card">

    <div class="auth-header">
        <div class="auth-app-name">Compendium</div>
        <div class="auth-app-sub">{{ 'nav.brand_sub'|trans }}</div>
    </div>

    {{ form_start(form, {'attr': {'class': 'auth-form', 'novalidate': true}}) }}

        {{ form_row(form.name) }}
        {{ form_row(form.email) }}
        {{ form_row(form.plainPassword) }}

        <button type="submit" class="btn btn-primary auth-submit-btn">
            {{ 'nav.register'|trans }} →
        </button>

    {{ form_end(form) }}

    <div class="auth-footer">
        {{ 'auth.register.already_account'|trans }}
        <a href="{{ path('app_login') }}">{{ 'nav.login'|trans }}</a>
    </div>

</div>

<div class="auth-quote">
    <i class="bi bi-book" aria-hidden="true"></i><br>
    "A reader lives a thousand lives before he dies."
</div>
{% endblock %}
