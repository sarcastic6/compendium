{% extends 'auth_base.html.twig' %}

{% block title %}{{ 'reset_password.check_email.heading'|trans }}{% endblock %}

{% block body %}
<div class="auth-card">

    <div class="auth-header">
        <div style="font-size: 2.5rem; margin-bottom: var(--space-3);">
            <i class="bi bi-envelope-check" aria-hidden="true" style="color: var(--color-primary-light);"></i>
        </div>
        <div class="auth-app-name" style="font-size: var(--text-xl);">
            {{ 'reset_password.check_email.heading'|trans }}
        </div>
    </div>

    <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0; text-align: center; line-height: var(--leading-relaxed);">
        {{ 'reset_password.check_email.instructions'|trans({'%expiry%': resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')}) }}
    </p>

    <div class="auth-footer">
        <a href="{{ path('app_login') }}">← {{ 'nav.login'|trans }}</a>
    </div>

</div>
{% endblock %}
