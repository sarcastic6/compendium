{% extends 'auth_base.html.twig' %}

{% block title %}{{ 'reset_password.request.heading'|trans }}{% endblock %}

{% block body %}
<div class="auth-card">

    <div class="auth-header">
        <div class="auth-app-name">Compendium</div>
        <div class="auth-app-sub">{{ 'reset_password.request.heading'|trans }}</div>
    </div>

    <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0; text-align: center;">
        {{ 'reset_password.request.instructions'|trans }}
    </p>

    {{ form_start(requestForm, {'attr': {'class': 'auth-form', 'novalidate': true}}) }}

        {{ form_row(requestForm.email) }}

        <button type="submit" class="btn btn-primary auth-submit-btn">
            {{ 'reset_password.request.submit'|trans }} →
        </button>

    {{ form_end(requestForm) }}

    <div class="auth-footer">
        <a href="{{ path('app_login') }}">← {{ 'nav.login'|trans }}</a>
    </div>

</div>
{% endblock %}
