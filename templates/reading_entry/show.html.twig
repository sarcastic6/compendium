{% extends 'base.html.twig' %}

{% block title %}
    {% if entry.work.deleted %}
        {{ 'reading.entry.title'|trans }}
    {% else %}
        {{ entry.work.title }}
    {% endif %}
{% endblock %}

{% block body %}

{# ── Page header ── #}
<div class="page-header">
    <div class="page-header-text">
        <a href="{{ path('app_reading_entry_list') }}" class="back-link">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            {{ 'nav.library'|trans }}
        </a>
    </div>
    <div class="page-header-actions">
        {% if not entry.work.deleted %}
            <a href="{{ path('app_work_show', {id: entry.work.id}) }}" class="btn btn-ghost btn-sm">
                <i class="bi bi-book" aria-hidden="true"></i>
                {{ 'reading.entry.view_work'|trans }}
            </a>
        {% endif %}
        <a href="{{ path('app_reading_entry_edit', {id: entry.id}) }}" class="btn btn-secondary btn-sm">
            <i class="bi bi-pencil" aria-hidden="true"></i>
            {{ 'reading.entry.edit'|trans }}
        </a>
        <button type="button" class="btn btn-danger btn-sm"
                data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash" aria-hidden="true"></i>
            {{ 'reading.entry.delete'|trans }}
        </button>
    </div>
</div>

<div class="row g-4 g-lg-5">

    {# ── Left column: cover art + status + actions ── #}
    <div class="col-12 col-md-4 col-lg-3">
        <div class="work-cover-col">

            {# Typographic cover #}
            {% if entry.work.deleted %}
                <div class="cover cover-lg" style="background: var(--color-surface-tint); opacity: 0.5;" aria-hidden="true">
                    <span class="cover-title" style="color: var(--color-text-faint);">{{ 'reading.entry.work_deleted'|trans }}</span>
                </div>
            {% else %}
                <div class="cover cover-lg {{ cover_font_class(entry.work.type.value) }}"
                     style="{{ cover_gradient(entry.work.id) }}"
                     aria-hidden="true">
                    <span class="cover-title">{{ entry.work.title }}</span>
                </div>
            {% endif %}

            {# Status chip #}
            {% set statusSlug = entry.status.name|lower|replace({' ': '-'}) %}
            <div class="mt-3">
                <span class="chip chip--{{ statusSlug }}">{{ entry.status.name }}</span>
            </div>

            {# Starred indicator #}
            {% if entry.starred %}
                <div class="mt-2" style="color: #f4b942; font-size: var(--text-sm);">
                    <i class="bi bi-heart-fill" aria-label="{{ 'reading.field.starred'|trans }}"></i>
                    {{ 'reading.field.starred'|trans }}
                </div>
            {% endif %}

        </div>
    </div>

    {# ── Right column: entry details ── #}
    <div class="col-12 col-md-8 col-lg-9">

        {# Work title + authors #}
        {% if entry.work.deleted %}
            <h1 class="work-detail-title" style="color: var(--color-text-faint);">
                {{ 'reading.entry.work_deleted'|trans }}
            </h1>
        {% else %}
            <h1 class="work-detail-title">
                <a href="{{ path('app_work_show', {id: entry.work.id}) }}"
                   class="text-decoration-none" style="color: inherit;">{{ entry.work.title }}</a>
                {% if entry.work.starred %}
                    <i class="bi bi-star-fill ms-1"
                       style="color: #f4b942; font-size: 0.6em; vertical-align: middle;"
                       aria-label="{{ 'entry.list.favorite_work'|trans }}"></i>
                {% endif %}
            </h1>
            {% if entry.work.authors is not empty %}
                <p class="work-detail-authors mt-1 mb-0">
                    {% for author in entry.work.authors %}
                        {{ author.name }}{% if not loop.last %}, {% endif %}
                    {% endfor %}
                </p>
            {% endif %}
        {% endif %}

        {# Stat boxes: dates + last chapter #}
        <div class="work-detail-stats">
            {% if entry.dateStarted %}
                <div class="work-stat-box">
                    <span class="work-stat-value">{{ entry.dateStarted|date }}</span>
                    <span class="work-stat-label">{{ 'reading.field.date_started'|trans }}</span>
                </div>
            {% endif %}
            {% if entry.dateFinished %}
                <div class="work-stat-box">
                    <span class="work-stat-value">{{ entry.dateFinished|date }}</span>
                    <span class="work-stat-label">{{ 'reading.field.date_finished'|trans }}</span>
                </div>
            {% endif %}
            {% if entry.lastReadChapter %}
                <div class="work-stat-box">
                    <span class="work-stat-value">{{ entry.lastReadChapter }}</span>
                    <span class="work-stat-label">{{ 'reading.field.last_chapter'|trans }}</span>
                </div>
            {% endif %}
        </div>

        {# Review + spice #}
        {% if entry.reviewStars or entry.spiceStars is not null %}
            <div class="d-flex flex-wrap gap-3 mt-4" style="font-size: var(--text-sm); color: var(--color-text-muted);">
                {% if entry.reviewStars %}
                    <div>
                        <span style="text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--text-xs); margin-right: var(--space-2);">
                            {{ 'reading.field.review_stars'|trans }}
                        </span>
                        <span aria-label="{{ entry.reviewStars }} {{ 'reading.field.review_stars'|trans }}">
                            {% for i in range(1, entry.reviewStars) %}⭐{% endfor %}
                        </span>
                    </div>
                {% endif %}
                {% if entry.spiceStars is not null %}
                    <div>
                        <span style="text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--text-xs); margin-right: var(--space-2);">
                            {{ 'reading.field.spice_stars'|trans }}
                        </span>
                        {% if entry.spiceStars == 0 %}
                            <span aria-label="No spice">🚫</span>
                        {% else %}
                            <span aria-label="{{ entry.spiceStars }} out of 5">
                                {% for i in range(1, entry.spiceStars) %}🌶️{% endfor %}
                            </span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {# Main pairing #}
        {% if entry.mainPairing %}
            <div class="mt-3">
                <span style="text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--text-xs); color: var(--color-text-muted); display: block; margin-bottom: var(--space-1);">
                    {{ 'reading.field.main_pairing'|trans }}
                </span>
                <span class="chip chip-tag">{{ entry.mainPairing.name }}</span>
            </div>
        {% endif %}

        {# Comments #}
        {% if entry.comments %}
            <div class="mt-4">
                <span style="text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--text-xs); color: var(--color-text-muted); display: block; margin-bottom: var(--space-2);">
                    {{ 'reading.field.comments'|trans }}
                </span>
                <div class="chart-card">
                    <div class="chart-card-body" style="white-space: pre-wrap; font-size: var(--text-sm); color: var(--color-text-body);">{{ entry.comments }}</div>
                </div>
            </div>
        {% endif %}

    </div>
</div>

{# ── Delete confirmation modal ── #}
{# CSRF token is hard-coded at render time; the form action is fixed to this entry's delete URL #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);">
            <div class="modal-header" style="border-bottom: 1px solid var(--color-border); padding: var(--space-4) var(--space-5);">
                <h5 class="modal-title" id="deleteModalLabel" style="font-weight: var(--weight-semibold); color: var(--color-primary);">
                    {{ 'reading.entry.delete_confirm'|trans }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        aria-label="{{ 'action.cancel'|trans }}"></button>
            </div>
            <div class="modal-body" style="padding: var(--space-5); color: var(--color-text-body);">
                {{ 'reading.entry.delete_confirm_message'|trans }}
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--color-border); padding: var(--space-4) var(--space-5);">
                <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">
                    {{ 'action.cancel'|trans }}
                </button>
                <form id="deleteForm" method="post" action="{{ path('app_reading_entry_delete', {id: entry.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-entry-' ~ entry.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                        {{ 'action.delete'|trans }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}
