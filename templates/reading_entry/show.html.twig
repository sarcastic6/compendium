{% extends 'base.html.twig' %}

{% block title %}
    {% if entry.work.deleted %}
        {{ 'reading.entry.title'|trans }}
    {% else %}
        {{ entry.work.title }}
    {% endif %}
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        {% if entry.work.deleted %}
            <h1 class="h3 mb-1 text-muted">{{ 'reading.entry.work_deleted'|trans }}</h1>
        {% else %}
            <h1 class="h3 mb-1">{{ entry.work.title }}</h1>
            {% if entry.work.authors is not empty %}
                <p class="text-muted mb-0">{{ entry.work.authors|map(a => a.name)|join(', ') }}</p>
            {% endif %}
        {% endif %}
    </div>
    <div class="d-flex flex-wrap gap-2 flex-shrink-0 ms-3">
        <a href="{{ path('app_reading_entry_edit', {id: entry.id}) }}" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil" aria-hidden="true"></i>
            {{ 'reading.entry.edit'|trans }}
        </a>
        <button type="button" class="btn btn-outline-danger btn-sm"
                data-bs-toggle="modal" data-bs-target="#deleteModal"
                data-entry-id="{{ entry.id }}"
                data-delete-url="{{ path('app_reading_entry_delete', {id: entry.id}) }}">
            <i class="bi bi-trash" aria-hidden="true"></i>
            {{ 'reading.entry.delete'|trans }}
        </button>
        <a href="{{ path('app_reading_entry_list') }}" class="btn btn-outline-secondary btn-sm">
            &larr; {{ 'reading.entry.back_to_list'|trans }}
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <dl class="row mb-0">
            <dt class="col-sm-5">{{ 'reading.field.status'|trans }}</dt>
            <dd class="col-sm-7">
                <span class="badge {% if entry.status.finished %}bg-success{% else %}bg-secondary{% endif %}">
                    {{ entry.status.name }}
                </span>
            </dd>

            <dt class="col-sm-5">{{ 'reading.field.date_started'|trans }}</dt>
            <dd class="col-sm-7">{{ entry.dateStarted ? entry.dateStarted|date('Y-m-d') : '—' }}</dd>

            <dt class="col-sm-5">{{ 'reading.field.date_finished'|trans }}</dt>
            <dd class="col-sm-7">{{ entry.dateFinished ? entry.dateFinished|date('Y-m-d') : '—' }}</dd>

            <dt class="col-sm-5">{{ 'reading.field.last_chapter'|trans }}</dt>
            <dd class="col-sm-7">{{ entry.lastReadChapter ?? '—' }}</dd>
        </dl>
    </div>
    <div class="col-md-6">
        <dl class="row mb-0">
            <dt class="col-sm-5">{{ 'reading.field.review_stars'|trans }}</dt>
            <dd class="col-sm-7">
                {% if entry.reviewStars %}
                    <span aria-label="{{ entry.reviewStars }} stars">
                        {% for i in range(1, entry.reviewStars) %}⭐{% endfor %}
                    </span>
                {% else %}
                    —
                {% endif %}
            </dd>

            <dt class="col-sm-5">{{ 'reading.field.spice_stars'|trans }}</dt>
            <dd class="col-sm-7">
                {% if entry.spiceStars is not null %}
                    {% if entry.spiceStars == 0 %}
                        <span aria-label="0 out of 5">🚫</span>
                    {% else %}
                        <span aria-label="{{ entry.spiceStars }} out of 5">
                            {% for i in range(1, entry.spiceStars) %}🌶️{% endfor %}
                        </span>
                    {% endif %}
                {% else %}
                    —
                {% endif %}
            </dd>

            <dt class="col-sm-5">{{ 'reading.field.main_pairing'|trans }}</dt>
            <dd class="col-sm-7">{{ entry.mainPairing ? entry.mainPairing.name : '—' }}</dd>

            <dt class="col-sm-5">{{ 'reading.field.starred'|trans }}</dt>
            <dd class="col-sm-7">
                {% if entry.starred %}
                    <i class="bi bi-heart-fill text-danger" aria-label="Yes"></i>
                {% else %}
                    —
                {% endif %}
            </dd>
        </dl>
    </div>
</div>

{% if entry.comments %}
    <div class="mb-4">
        <h2 class="h6 text-muted text-uppercase mb-2">{{ 'reading.field.comments'|trans }}</h2>
        <p class="mb-0" style="white-space: pre-wrap">{{ entry.comments }}</p>
    </div>
{% endif %}

{% if not entry.work.deleted %}
    <div class="border-top pt-3">
        <a href="{{ path('app_work_show', {id: entry.work.id}) }}" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-book" aria-hidden="true"></i>
            {{ 'reading.entry.view_work'|trans }}
        </a>
    </div>
{% endif %}

{# Delete confirmation modal — CSRF token protects against cross-site deletion #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">{{ 'reading.entry.delete_confirm'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.cancel'|trans }}"></button>
            </div>
            <div class="modal-body">
                {{ 'reading.entry.delete_confirm_message'|trans }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    {{ 'action.cancel'|trans }}
                </button>
                <form id="deleteForm" method="post" action="">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-entry-' ~ entry.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                        {{ 'action.delete'|trans }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var deleteModal = document.getElementById('deleteModal');
    if (deleteModal) {
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var deleteUrl = button.getAttribute('data-delete-url');
            document.getElementById('deleteForm').action = deleteUrl;
        });
    }
});
</script>
{% endblock %}
