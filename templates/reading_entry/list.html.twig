{% extends 'base.html.twig' %}

{% block title %}{{ 'reading.entry.list_heading'|trans }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">{{ 'reading.entry.list_heading'|trans }}</h1>
    <a href="{{ path('app_work_select') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        {{ 'reading.entry.add'|trans }}
    </a>
</div>

{# Filter bar #}
<div class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" type="button"
            data-bs-toggle="collapse" data-bs-target="#filterBar" aria-expanded="{{ has_filters ? 'true' : 'false' }}"
            aria-controls="filterBar">
        <i class="bi bi-funnel" aria-hidden="true"></i>
        {{ 'reading.filter.show_filters'|trans }}
        {% if has_filters %}
            <span class="badge bg-primary ms-1">{{ filters|filter(v => v is not empty)|length }}</span>
        {% endif %}
    </button>
    {% if has_filters %}
        <a href="{{ path('app_reading_entry_list') }}" class="btn btn-outline-secondary btn-sm ms-1">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
            {{ 'reading.filter.clear'|trans }}
        </a>
    {% endif %}
</div>

<div class="collapse {% if has_filters %}show{% endif %}" id="filterBar">
    <form method="get" action="{{ path('app_reading_entry_list') }}" class="card card-body bg-light border-0 mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label for="filter-q" class="form-label form-label-sm">{{ 'reading.entry.col_title'|trans }}</label>
                <input type="text" id="filter-q" name="q" class="form-control form-control-sm"
                       value="{{ filters.q }}"
                       placeholder="{{ 'reading.filter.search_placeholder'|trans }}">
            </div>
            <div class="col-md-3">
                <label for="filter-author" class="form-label form-label-sm">{{ 'reading.filter.author'|trans }}</label>
                <input type="text" id="filter-author" name="author" class="form-control form-control-sm"
                       value="{{ filters.author }}"
                       placeholder="{{ 'reading.filter.author_placeholder'|trans }}">
            </div>
            <div class="col-md-2">
                <label for="filter-status" class="form-label form-label-sm">{{ 'reading.filter.status'|trans }}</label>
                <select id="filter-status" name="status" class="form-select form-select-sm">
                    <option value="">{{ 'reading.filter.any_status'|trans }}</option>
                    {% for status in statuses %}
                        <option value="{{ status.id }}" {% if filters.status == (status.id ~ '') %}selected{% endif %}>
                            {{ status.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label for="filter-rating" class="form-label form-label-sm">{{ 'reading.filter.rating'|trans }}</label>
                <select id="filter-rating" name="rating" class="form-select form-select-sm">
                    <option value="">{{ 'reading.filter.any_rating'|trans }}</option>
                    {% for i in 1..5 %}
                        <option value="{{ i }}" {% if filters.rating == (i ~ '') %}selected{% endif %}>
                            {% for j in 1..i %}⭐{% endfor %}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" id="filter-starred" name="starred" value="1"
                           {% if filters.starred == '1' %}checked{% endif %}>
                    <label class="form-check-label" for="filter-starred">
                        {{ 'reading.filter.starred'|trans }}
                    </label>
                </div>
            </div>
        </div>
        <div class="row g-2 align-items-end mt-1">
            <div class="col-md-2">
                <label for="filter-date-from" class="form-label form-label-sm">{{ 'reading.filter.date_from'|trans }}</label>
                <input type="date" id="filter-date-from" name="dateFrom" class="form-control form-control-sm"
                       value="{{ filters.dateFrom }}">
            </div>
            <div class="col-md-2">
                <label for="filter-date-to" class="form-label form-label-sm">{{ 'reading.filter.date_to'|trans }}</label>
                <input type="date" id="filter-date-to" name="dateTo" class="form-control form-control-sm"
                       value="{{ filters.dateTo }}">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    {{ 'reading.filter.show_filters'|trans }}
                </button>
            </div>
        </div>
    </form>
</div>

{% if entries is empty %}
    <div class="text-center py-5 text-muted">
        {% if has_filters %}
            <p class="mb-3">No entries match your filters.</p>
            <a href="{{ path('app_reading_entry_list') }}" class="btn btn-outline-secondary">
                {{ 'reading.filter.clear'|trans }}
            </a>
        {% else %}
            <p class="mb-3">{{ 'reading.entry.empty'|trans }}</p>
            <a href="{{ path('app_work_select') }}" class="btn btn-outline-primary">
                {{ 'reading.entry.add'|trans }}
            </a>
        {% endif %}
    </div>
{% else %}
    {# Bulk actions form — wraps the table so checkboxes are inside the form #}
    <form id="bulk-form" method="post" action="">
        <input type="hidden" name="_token" id="bulk-token" value="{{ csrf_token('bulk-action') }}">
        <input type="hidden" name="_query" value="{{ app.request.queryString }}">

        {# Bulk action bar — shown by JS when entries are checked #}
        <div id="bulk-action-bar" class="d-none sticky-bottom bg-white border-top py-2 px-3 shadow-sm" aria-live="polite">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span id="bulk-count" class="text-muted me-2"></span>
                <div class="d-flex gap-2">
                    <select id="bulk-status-select" name="status_id" class="form-select form-select-sm" style="width: auto;">
                        <option value="">{{ 'reading.bulk.change_status'|trans }}</option>
                        {% for status in statuses %}
                            <option value="{{ status.id }}">{{ status.name }}</option>
                        {% endfor %}
                    </select>
                    <button type="button" id="bulk-status-btn" class="btn btn-outline-secondary btn-sm"
                            data-action-url="{{ path('app_reading_entry_bulk_status') }}">
                        {{ 'reading.bulk.apply_status'|trans }}
                    </button>
                </div>
                <button type="button" id="bulk-delete-btn" class="btn btn-outline-danger btn-sm"
                        data-bs-toggle="modal" data-bs-target="#bulkDeleteModal"
                        data-action-url="{{ path('app_reading_entry_bulk_delete') }}">
                    <i class="bi bi-trash" aria-hidden="true"></i>
                    {{ 'reading.bulk.delete_selected'|trans }}
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle table-responsive-card">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="pe-0" style="width: 1%">
                            <input class="form-check-input" type="checkbox" id="select-all"
                                   aria-label="{{ 'reading.bulk.select_all'|trans }}">
                        </th>
                        <th scope="col">{{ 'reading.entry.col_title'|trans }}</th>
                        <th scope="col">{{ 'reading.entry.col_authors'|trans }}</th>
                        <th scope="col">{{ 'reading.field.status'|trans }}</th>
                        <th scope="col">{{ 'reading.field.date_finished'|trans }}</th>
                        <th scope="col">{{ 'reading.field.review_stars'|trans }}</th>
                        <th scope="col"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in entries %}
                        <tr>
                            <td class="pe-0">
                                <input class="form-check-input entry-checkbox" type="checkbox"
                                       name="ids[]" value="{{ entry.id }}"
                                       aria-label="{{ entry.work.deleted ? 'reading.entry.work_deleted'|trans : entry.work.title }}">
                            </td>
                            <td data-label="{{ 'reading.entry.col_title'|trans }}">
                                {% if entry.work.deleted %}
                                    <span class="entry-deleted-work">
                                        {{ 'reading.entry.work_deleted'|trans }}
                                    </span>
                                {% else %}
                                    <a href="{{ path('app_reading_entry_show', {id: entry.id}) }}">{{ entry.work.title }}</a>
                                    {% if entry.work.starred %}
                                        <i class="bi bi-star-fill text-warning ms-1" aria-label="Favorite work"></i>
                                    {% endif %}
                                {% endif %}
                            </td>
                            <td data-label="{{ 'reading.entry.col_authors'|trans }}">
                                {% if not entry.work.deleted %}
                                    {{ entry.work.authors|map(a => a.name)|join(', ')|default('—') }}
                                {% endif %}
                            </td>
                            <td data-label="{{ 'reading.field.status'|trans }}">
                                <span class="badge {% if entry.status.countsAsRead %}bg-success{% else %}bg-secondary{% endif %}">
                                    {{ entry.status.name }}
                                </span>
                            </td>
                            <td data-label="{{ 'reading.field.date_finished'|trans }}">
                                {{ entry.dateFinished ? entry.dateFinished|date('Y-m-d') : '—' }}
                            </td>
                            <td data-label="{{ 'reading.field.review_stars'|trans }}">
                                {% if entry.reviewStars %}
                                    <span class="stars-display" aria-label="{{ entry.reviewStars }} stars">
                                        {% for i in range(1, entry.reviewStars) %}⭐{% endfor %}
                                    </span>
                                {% else %}
                                    —
                                {% endif %}
                                {% if entry.starred %}
                                    <i class="bi bi-heart-fill text-danger ms-1" aria-label="Favorite entry"></i>
                                {% endif %}
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="{{ path('app_reading_entry_edit', {id: entry.id}) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil" aria-hidden="true"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            data-entry-id="{{ entry.id }}"
                                            data-delete-url="{{ path('app_reading_entry_delete', {id: entry.id}) }}"
                                            data-csrf-token="{{ csrf_token('delete-entry-' ~ entry.id) }}"
                                            aria-label="{{ 'reading.entry.delete'|trans }}">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </button>
                                    {% if not entry.work.deleted %}
                                        <a href="{{ path('app_work_show', {id: entry.work.id}) }}"
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-book" aria-hidden="true"></i>
                                            {{ 'reading.entry.view_work'|trans }}
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </form>

    {# Pagination #}
    {% if total_pages > 1 %}
        <nav aria-label="Reading entries pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item {% if page <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_reading_entry_list', filters|merge({page: page - 1})) }}"
                       aria-label="{{ 'pagination.previous'|trans }}">
                        &laquo; {{ 'pagination.previous'|trans }}
                    </a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">
                        {{ page }} / {{ total_pages }}
                    </span>
                </li>
                <li class="page-item {% if page >= total_pages %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_reading_entry_list', filters|merge({page: page + 1})) }}"
                       aria-label="{{ 'pagination.next'|trans }}">
                        {{ 'pagination.next'|trans }} &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endif %}

{# Single-entry delete confirmation modal #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">{{ 'reading.entry.delete_confirm'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.cancel'|trans }}"></button>
            </div>
            <div class="modal-body">
                {{ 'reading.entry.delete_confirm_message'|trans }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    {{ 'action.cancel'|trans }}
                </button>
                <form id="singleDeleteForm" method="post" action="">
                    <input type="hidden" name="_token" id="singleDeleteToken" value="">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                        {{ 'action.delete'|trans }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

{# Bulk delete confirmation modal #}
<div class="modal fade" id="bulkDeleteModal" tabindex="-1" aria-labelledby="bulkDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bulkDeleteModalLabel">{{ 'reading.entry.delete_confirm'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'action.cancel'|trans }}"></button>
            </div>
            <div class="modal-body">
                {{ 'reading.bulk.confirm_bulk_delete'|trans }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    {{ 'action.cancel'|trans }}
                </button>
                <button type="button" id="bulk-delete-confirm-btn" class="btn btn-danger">
                    <i class="bi bi-trash" aria-hidden="true"></i>
                    {{ 'reading.bulk.delete_selected'|trans }}
                </button>
            </div>
        </div>
    </div>
</div>

<script type="module" src="{{ asset('js/bulk-actions.js') }}"></script>

<script>
// Wire single-entry delete modal: set action URL and CSRF token from the triggering button's data attributes
document.addEventListener('DOMContentLoaded', function () {
    var deleteModal = document.getElementById('deleteModal');
    if (!deleteModal) { return; }
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        if (!button) { return; }
        var form = document.getElementById('singleDeleteForm');
        var tokenInput = document.getElementById('singleDeleteToken');
        if (form) { form.action = button.getAttribute('data-delete-url') || ''; }
        if (tokenInput) { tokenInput.value = button.getAttribute('data-csrf-token') || ''; }
    });
});
</script>
{% endblock %}
