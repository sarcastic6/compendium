{% extends 'base.html.twig' %}

{% block title %}{{ 'entry.list.heading'|trans }}{% endblock %}

{% block body %}

{# ── Page header ──────────────────────────────────────────────────────────── #}
<div class="page-header">
    <div class="page-header-text">
        <h1 class="page-title">{{ 'entry.list.heading'|trans }}</h1>
        <p class="page-subtitle text-muted mb-0">
            {% if has_filters %}
                {{ 'entry.list.entry_count_filtered'|trans({'%count%': total, '%total%': stat_total_words|number_format}) }}
            {% else %}
                {% if total == 1 %}
                    {{ 'entry.list.entry_count_one'|trans({'%count%': total}) }}
                {% else %}
                    {{ 'entry.list.entry_count'|trans({'%count%': total}) }}
                {% endif %}
            {% endif %}
        </p>
    </div>
    <div class="page-header-actions">
        {# Filter toggle — offcanvas trigger #}
        <button class="btn btn-secondary btn-sm" type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#filterOffcanvas"
                aria-controls="filterOffcanvas">
            <i class="bi bi-funnel" aria-hidden="true"></i>
            {{ 'entry.filter.show_filters'|trans }}
            {% if has_filters %}
                <span class="filter-badge ms-1">{{ active_filter_count }}</span>
            {% endif %}
        </button>
        <a href="{{ path('app_work_select') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            {{ 'entry.list.add'|trans }}
        </a>
    </div>
</div>

{# ── Summary stat strip ───────────────────────────────────────────────────── #}
<div class="stat-strip">
    <div class="stat-strip-item">
        <span class="stat-strip-value">{{ stat_total_words|number_format }}</span>
        <span class="stat-strip-label">{{ 'entry.list.stat_total_words'|trans }}</span>
    </div>
    <div class="stat-strip-item">
        <span class="stat-strip-value">{{ stat_finish_rate }}%</span>
        <span class="stat-strip-label">{{ 'entry.list.stat_finish_rate'|trans }}</span>
    </div>
    <div class="stat-strip-item">
        {% if stat_avg_review %}
            <span class="stat-strip-value">{{ stat_avg_review }}</span>
        {% else %}
            <span class="stat-strip-value stat-strip-value--empty">—</span>
        {% endif %}
        <span class="stat-strip-label">{{ 'entry.list.stat_avg_review'|trans }}</span>
    </div>
    <div class="stat-strip-item">
        {% if has_filters %}
            <span class="stat-strip-value">{{ stat_completed }}</span>
            <span class="stat-strip-label">{{ 'entry.list.stat_completed'|trans }}</span>
        {% else %}
            <span class="stat-strip-value">{{ stat_this_year }}</span>
            <span class="stat-strip-label">{{ 'entry.list.stat_this_year'|trans({'%year%': stat_current_year}) }}</span>
        {% endif %}
    </div>
</div>

{# ── Pinned entries section — hidden when nothing is pinned ───────────────── #}
{% if pinned_entries is not empty %}
<section class="pinned-section mb-4" aria-label="{{ 'reading.entry.pinned_heading'|trans }}">
    <h2 class="pinned-section-heading">
        <i class="bi bi-pin-angle-fill me-2" aria-hidden="true"></i>
        {{ 'reading.entry.pinned_heading'|trans }}
    </h2>
    <div class="table-wrapper" style="overflow: visible;">
        <table class="data-table table-responsive-card">
            <thead>
                <tr>
                    <th class="cover-col d-none d-md-table-cell" aria-hidden="true"></th>
                    <th class="d-none d-md-table-cell">{{ 'reading.entry.col_title'|trans }}</th>
                    <th class="d-none d-lg-table-cell">{{ 'entry.list.col_fandom'|trans }}</th>
                    <th class="words-col d-none d-md-table-cell">{{ 'reading.entry.col_words'|trans }}</th>
                    <th class="d-none d-md-table-cell">{{ 'reading.field.status'|trans }}</th>
                    <th class="d-none d-lg-table-cell">{{ 'reading.entry.col_date_finished'|trans }}</th>
                    <th class="d-none d-md-table-cell">{{ 'reading.entry.col_review_spice'|trans }}</th>
                    <th class="actions-col d-none d-md-table-cell"></th>
                </tr>
            </thead>
            <tbody>
                {% for entry in pinned_entries %}
                    {% include 'reading_entry/_entry_row.html.twig' with {entry: entry, showCheckbox: false} only %}
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endif %}

{# ── Active filter chips — always visible when filters are set ────────────── #}
{% include 'reading_entry/_filter_chips.html.twig' with {
    has_filters: has_filters,
    filters: filters,
    statuses: statuses,
    seriesName: seriesName ?? null
} only %}

{# ── Empty state ──────────────────────────────────────────────────────────── #}
{% if entries is empty %}
    <div class="table-empty-state">
        {% if has_filters %}
            <div class="table-empty-icon">
                <i class="bi bi-funnel" aria-hidden="true"></i>
            </div>
            <p class="table-empty-title">{{ 'entry.empty.no_results_heading'|trans }}</p>
            <p class="table-empty-text">{{ 'entry.empty.no_results_text'|trans }}</p>
            <a href="{{ path('app_reading_entry_list') }}" class="btn btn-secondary btn-sm mt-3">
                {{ 'entry.filter.clear_all'|trans }}
            </a>
        {% else %}
            <div class="table-empty-icon">
                <i class="bi bi-book" aria-hidden="true"></i>
            </div>
            <p class="table-empty-title">{{ 'entry.empty.heading'|trans }}</p>
            <p class="table-empty-text">{{ 'entry.empty.text'|trans }}</p>
            <a href="{{ path('app_work_select') }}" class="btn btn-primary btn-sm mt-3">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                {{ 'entry.list.add'|trans }}
            </a>
        {% endif %}
    </div>
{% else %}

{# ── Bulk actions form — wraps the table so checkboxes are inside the form ── #}
<form id="bulk-form" method="post" action="">
    <input type="hidden" name="_token" id="bulk-token" value="{{ csrf_token('bulk-action') }}">
    <input type="hidden" name="_query" value="{{ app.request.queryString }}">

    {# Bulk action bar — shown by JS when entries are checked #}
    <div id="bulk-action-bar" class="d-none bulk-action-bar" aria-live="polite">
        <span id="bulk-count" class="bulk-selected-count"></span>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <select id="bulk-status-select" name="status_id" class="form-select form-select-sm" style="width: auto;">
                <option value="">{{ 'reading.bulk.change_status'|trans }}</option>
                {% for status in statuses %}
                    <option value="{{ status.id }}">{{ status.name }}</option>
                {% endfor %}
            </select>
            <button type="button" id="bulk-status-btn" class="btn btn-secondary btn-sm"
                    data-action-url="{{ path('app_reading_entry_bulk_status') }}">
                {{ 'reading.bulk.apply_status'|trans }}
            </button>
        </div>
        <button type="button" id="bulk-delete-btn" class="btn btn-outline-danger btn-sm ms-auto"
                data-bs-toggle="modal" data-bs-target="#bulkDeleteModal"
                data-action-url="{{ path('app_reading_entry_bulk_delete') }}">
            <i class="bi bi-trash" aria-hidden="true"></i>
            {{ 'reading.bulk.delete_selected'|trans }}
        </button>
    </div>

    {# ── Entry table ─────────────────────────────────────────────────────── #}
    <div class="table-wrapper">
        <table class="data-table table-responsive-card">
            <thead>
                <tr>
                    <th scope="col" style="width: 1%; padding-right: 0;">
                        <input class="form-check-input" type="checkbox" id="select-all"
                               aria-label="{{ 'reading.bulk.select_all'|trans }}">
                    </th>
                    <th scope="col" class="cover-col" aria-hidden="true"></th>
                    {# Title + Author compound sort header #}
                    <th scope="col"{% if current_sort in ['title', 'author'] %} class="th-sort-active"{% endif %}>
                        {% set isActive = current_sort == 'title' %}
                        {% set nextDir = isActive and current_dir == 'asc' ? 'desc' : 'asc' %}
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'title', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
                            {{ 'reading.entry.col_title'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                        {% set isActive = current_sort == 'author' %}
                        {% set nextDir = isActive and current_dir == 'asc' ? 'desc' : 'asc' %}
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'author', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}"
                           style="font-size: 0.8em; font-weight: normal;">
                            {{ 'reading.filter.author'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                    </th>

                    {# Fandom + Main Pairing header — not sortable #}
                    <th scope="col" class="d-none d-lg-table-cell">
                        <span class="text-muted">{{ 'entry.list.col_fandom'|trans }}</span>
                        <div class="text-muted" style="font-size: 0.8em; font-weight: normal;">
                            <i class="bi bi-heart" aria-hidden="true" style="color: #e05c7a;"></i>
                            {{ 'reading.field.main_pairing'|trans }}
                        </div>
                    </th>

                    <th scope="col">{{ 'reading.entry.col_words'|trans }}</th>

                    {# Status sort header #}
                    {% set isActive = current_sort == 'status' %}
                    {% set nextDir = isActive and current_dir == 'asc' ? 'desc' : 'asc' %}
                    <th scope="col"{% if isActive %} class="th-sort-active"{% endif %}>
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'status', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
                            {{ 'reading.field.status'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                    </th>

                    {# Date Finished sort header — hidden on small screens #}
                    {% set isActive = current_sort == 'dateFinished' %}
                    {% set nextDir = isActive and current_dir == 'desc' ? 'asc' : 'desc' %}
                    <th scope="col" class="d-none d-lg-table-cell{% if isActive %} th-sort-active{% endif %}">
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'dateFinished', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
                            {{ 'reading.entry.col_date_finished'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                    </th>
                    <th scope="col">{{ 'reading.entry.col_review_spice'|trans }}</th>
                    <th scope="col" class="actions-col"></th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                    {# Determine status chip modifier class from status name (case-insensitive) #}
                    {% set statusSlug = entry.status.name|lower|replace({' ': '-'}) %}
                    {% set chipClass = 'chip chip--' ~ statusSlug %}

                    {# Fandom: first fandom metadata on the work (if any) #}
                    {% set fandomName = null %}
                    {% if not entry.work.deleted %}
                        {% for m in entry.work.metadata %}
                            {% if fandomName is null and m.metadataType.name == 'Fandom' %}
                                {% set fandomName = m.name %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    <tr>
                        {# Checkbox — hidden on mobile (replaced by mobile card) #}
                        <td class="pe-0 d-none d-md-table-cell">
                            <input class="form-check-input entry-checkbox" type="checkbox"
                                   name="ids[]" value="{{ entry.id }}"
                                   aria-label="{{ entry.work.deleted ? 'reading.entry.work_deleted'|trans : entry.work.title }}">
                        </td>

                        {# Cover art thumbnail — hidden on mobile (shown inside mobile card) #}
                        <td class="cover-col d-none d-md-table-cell" aria-hidden="true">
                            {% if not entry.work.deleted %}
                                <div class="cover cover-thumbnail {{ cover_font_class(entry.work.type.value) }}"
                                     style="{{ cover_gradient(entry.work.id) }}">
                                    <span class="cover-title">{{ entry.work.title }}</span>
                                </div>
                            {% endif %}
                        </td>

                        {# Title + author stacked — hidden on mobile #}
                        <td data-label="{{ 'reading.entry.col_title'|trans }}" class="d-none d-md-table-cell">
                            <div class="entry-title-cell">
                                {% if entry.work.deleted %}
                                    <span class="entry-deleted-work entry-title">
                                        {{ 'reading.entry.work_deleted'|trans }}
                                    </span>
                                {% else %}
                                    <div class="entry-title">
                                        <a href="{{ path('app_reading_entry_show', {id: entry.id}) }}"
                                           class="text-decoration-none" style="color: inherit;">
                                            {{ entry.work.title }}
                                        </a>
                                        {% if entry.pinned %}
                                            <i class="bi bi-pin-angle-fill ms-1" style="color: #e05c7a; font-size: 0.7em;"
                                               aria-label="{{ 'entry.list.pinned_entry'|trans }}"></i>
                                        {% endif %}
                                        {% if entry.comments %}
                                            <button type="button"
                                                    class="btn-ghost entry-comment-trigger"
                                                    data-bs-toggle="offcanvas"
                                                    data-bs-target="#commentOffcanvas"
                                                    data-comment-title="{{ entry.work.title|e('html_attr') }}"
                                                    data-comment-body="{{ entry.comments|e('html_attr') }}"
                                                    aria-label="{{ 'entry.list.view_comment'|trans }}">
                                                <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                                            </button>
                                        {% endif %}
                                    </div>
                                    <div class="entry-author">
                                        {{ entry.work.authors|map(a => a.name)|join(', ')|default('—') }}
                                    </div>
                                {% endif %}
                            </div>
                        </td>

                        {# Fandom — first fandom only, hidden on small screens #}
                        <td data-label="{{ 'entry.list.col_fandom'|trans }}"
                            class="d-none d-lg-table-cell">
                            {% if fandomName %}
                                <span class="entry-author">{{ fandomName }}</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                            {% if entry.mainPairing %}
                                <div class="entry-author mt-1" style="font-size: 0.85em;">
                                    <i class="bi bi-heart" aria-hidden="true" style="color: #e05c7a;"></i>
                                    {{ entry.mainPairing.name }}
                                </div>
                            {% endif %}
                        </td>

                        {# Word count — hidden on mobile #}
                        <td data-label="{{ 'reading.entry.col_words'|trans }}" class="words-col d-none d-md-table-cell">
                            {{ entry.work.words ? entry.work.words|number_format : '—' }}
                        </td>

                        {# Status chip — hidden on mobile #}
                        <td data-label="{{ 'reading.field.status'|trans }}" class="d-none d-md-table-cell">
                            <span class="{{ chipClass }}">{{ entry.status.name }}</span>
                            {% if not entry.status.countsAsRead and entry.lastReadChapter %}
                                {% if entry.work.chapters %}
                                    {% set pct = (entry.lastReadChapter / entry.work.chapters * 100)|round %}
                                    {% if pct > 100 %}{% set pct = 100 %}{% endif %}
                                    <div class="text-muted mt-1" style="font-size: 0.72rem; white-space: nowrap;">
                                        ch. {{ entry.lastReadChapter }} / {{ entry.work.chapters }}
                                    </div>
                                    <div class="progress mt-1" style="height: 3px; width: 80px;">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: {{ pct }}%"
                                             aria-valuenow="{{ pct }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                {% else %}
                                    <div class="text-muted mt-1" style="font-size: 0.72rem;">
                                        ch. {{ entry.lastReadChapter }}
                                    </div>
                                {% endif %}
                            {% endif %}
                        </td>

                        {# Date finished — hidden on small screens #}
                        <td data-label="{{ 'reading.entry.col_date_finished'|trans }}"
                            class="d-none d-lg-table-cell">
                            {% if entry.dateFinished %}
                                {{ entry.dateFinished|date }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>

                        {# Review stars — hidden on mobile #}
                        <td data-label="{{ 'reading.entry.col_review_spice'|trans }}" class="d-none d-md-table-cell">
                            {% if entry.reviewStars %}
                                <span class="stars-display" aria-label="{{ entry.reviewStars }} {{ 'entry.list.stars'|trans }}">
                                    {%- for i in 1..5 -%}
                                        {{- i <= entry.reviewStars ? '★' : '☆' -}}
                                    {%- endfor -%}
                                </span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                            {% if entry.spiceStars is not null %}
                                <div style="font-size: 0.75em; margin-top: 2px;">
                                    {% if entry.spiceStars == 0 %}🚫
                                    {% else %}{% for i in range(1, entry.spiceStars) %}🌶️{% endfor %}{% endif %}
                                </div>
                            {% endif %}
                        </td>

                        {# Actions menu — hidden on mobile #}
                        <td class="actions-col d-none d-md-table-cell">
                            <div class="dropdown">
                                <button class="btn btn-ghost btn-icon btn-sm"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false"
                                        aria-label="{{ 'entry.list.actions'|trans }}">
                                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="{{ path('app_reading_entry_edit', {id: entry.id}) }}">
                                            <i class="bi bi-pencil me-2" aria-hidden="true"></i>
                                            {{ 'action.edit'|trans }}
                                        </a>
                                    </li>
                                    <li>
                                        <button type="button" class="dropdown-item"
                                                data-pin-url="{{ path('app_reading_entry_toggle_pin', {id: entry.id}) }}"
                                                data-pin-token="{{ csrf_token('pin-entry-' ~ entry.id) }}"
                                                onclick="var f=document.getElementById('pin-form');f.action=this.dataset.pinUrl;document.getElementById('pin-form-token').value=this.dataset.pinToken;f.submit();">
                                            <i class="bi bi-{{ entry.pinned ? 'pin-angle' : 'pin-angle-fill' }} me-2" aria-hidden="true"></i>
                                            {{ (entry.pinned ? 'action.unpin' : 'action.pin')|trans }}
                                        </button>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button type="button" class="dropdown-item text-danger"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                data-entry-id="{{ entry.id }}"
                                                data-delete-url="{{ path('app_reading_entry_delete', {id: entry.id}) }}"
                                                data-csrf-token="{{ csrf_token('delete-entry-' ~ entry.id) }}">
                                            <i class="bi bi-trash me-2" aria-hidden="true"></i>
                                            {{ 'action.delete'|trans }}
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </td>

                        {# ── Mobile card — only visible below md ────────────────────── #}
                        {# The td is the tap target so both collapsed and expanded zones collapse on tap.
                           Interactive elements inside the expanded section stop propagation. #}
                        <td colspan="9" class="d-md-none entry-mobile-card"
                            role="button"
                            tabindex="0"
                            data-bs-toggle="collapse"
                            data-bs-target="#mc-{{ entry.id }}"
                            aria-expanded="false"
                            aria-controls="mc-{{ entry.id }}">

                            {# Collapsed card #}
                            <div class="mobile-entry-card">

                                {# Zone 1: thumbnail + title / author / words side by side #}
                                <div class="me-zone1">
                                    {% if not entry.work.deleted %}
                                        <div class="me-cover" aria-hidden="true">
                                            <div class="cover cover-thumbnail {{ cover_font_class(entry.work.type.value) }}"
                                                 style="{{ cover_gradient(entry.work.id) }}">
                                                <span class="cover-title">{{ entry.work.title }}</span>
                                            </div>
                                        </div>
                                    {% endif %}
                                    <div class="me-info">
                                        <div class="me-title">
                                            {% if entry.work.deleted %}
                                                <span class="entry-deleted-work">{{ 'reading.entry.work_deleted'|trans }}</span>
                                            {% else %}
                                                {{ entry.work.title }}
                                                {% if entry.pinned %}
                                                    <i class="bi bi-pin-angle-fill ms-1" style="color: #e05c7a; font-size: 0.7em;"
                                                       aria-label="{{ 'entry.list.pinned_entry'|trans }}"></i>
                                                {% endif %}
                                                {% if entry.comments %}
                                                    <i class="bi bi-chat-left-text me-comment-indicator ms-1"
                                                       aria-label="{{ 'entry.list.view_comment'|trans }}"></i>
                                                {% endif %}
                                            {% endif %}
                                        </div>
                                        {% if not entry.work.deleted %}
                                            <div class="me-author">
                                                {{ entry.work.authors|map(a => a.name)|join(', ')|default('—') }}
                                            </div>
                                            {% if entry.work.words %}
                                                <div class="me-meta">{{ entry.work.words|number_format }} words</div>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>

                                {# Zone 2: status + optional progress + stars/spice (full width, always consistent) #}
                                <div class="me-zone2">
                                    <div class="me-status-row">
                                        <span class="{{ chipClass }}">{{ entry.status.name }}</span>
                                        {% if not entry.status.countsAsRead and entry.lastReadChapter %}
                                            <div class="me-progress">
                                                <span class="me-progress-text">
                                                    ch. {{ entry.lastReadChapter }}{% if entry.work.chapters %} / {{ entry.work.chapters }}{% endif %}
                                                </span>
                                                {% if entry.work.chapters %}
                                                    {% set pct = (entry.lastReadChapter / entry.work.chapters * 100)|round %}
                                                    {% if pct > 100 %}{% set pct = 100 %}{% endif %}
                                                    <div class="progress" style="height: 3px; width: 60px; flex-shrink: 0;">
                                                        <div class="progress-bar" role="progressbar"
                                                             style="width: {{ pct }}%"
                                                             aria-valuenow="{{ pct }}" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    {% if entry.reviewStars or entry.spiceStars is not null %}
                                        <div class="me-review mt-1">
                                            {% if entry.reviewStars %}
                                                <span class="stars-display" aria-label="{{ entry.reviewStars }} {{ 'entry.list.stars'|trans }}">
                                                    {%- for i in 1..5 -%}
                                                        {{- i <= entry.reviewStars ? '★' : '☆' -}}
                                                    {%- endfor -%}
                                                </span>
                                            {% endif %}
                                            {% if entry.spiceStars is not null %}
                                                <span>
                                                    {% if entry.spiceStars == 0 %}🚫
                                                    {% else %}{% for i in range(1, entry.spiceStars) %}🌶️{% endfor %}{% endif %}
                                                </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>

                            {# Expanded section — revealed on tap #}
                            <div class="collapse mobile-entry-expanded" id="mc-{{ entry.id }}">

                                {# Action buttons — always at top for immediate access.
                                   stopPropagation prevents the td toggle from firing when tapping a button. #}
                                <div class="me-actions">
                                    {% if not entry.work.deleted %}
                                        <a href="{{ path('app_work_show', {id: entry.work.id}) }}"
                                           class="me-action-btn" aria-label="{{ 'reading.entry.view_work'|trans }}"
                                           onclick="event.stopPropagation()">
                                            <i class="bi bi-book" aria-hidden="true"></i>
                                        </a>
                                    {% endif %}
                                    <a href="{{ path('app_reading_entry_edit', {id: entry.id}) }}"
                                       class="me-action-btn" aria-label="{{ 'action.edit'|trans }}"
                                       onclick="event.stopPropagation()">
                                        <i class="bi bi-pencil" aria-hidden="true"></i>
                                    </a>
                                    <button type="button"
                                            class="me-action-btn{{ entry.pinned ? ' me-action-btn--pinned' : '' }}"
                                            aria-label="{{ (entry.pinned ? 'action.unpin' : 'action.pin')|trans }}"
                                            data-pin-url="{{ path('app_reading_entry_toggle_pin', {id: entry.id}) }}"
                                            data-pin-token="{{ csrf_token('pin-entry-' ~ entry.id) }}"
                                            onclick="event.stopPropagation();var f=document.getElementById('pin-form');f.action=this.dataset.pinUrl;document.getElementById('pin-form-token').value=this.dataset.pinToken;f.submit();">
                                        <i class="bi bi-{{ entry.pinned ? 'pin-angle-fill' : 'pin-angle' }}" aria-hidden="true"></i>
                                    </button>
                                    <button type="button"
                                            class="me-action-btn me-action-btn--danger"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal"
                                            data-entry-id="{{ entry.id }}"
                                            data-delete-url="{{ path('app_reading_entry_delete', {id: entry.id}) }}"
                                            data-csrf-token="{{ csrf_token('delete-entry-' ~ entry.id) }}"
                                            aria-label="{{ 'action.delete'|trans }}"
                                            onclick="event.stopPropagation()">
                                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                                    </button>
                                </div>

                                {# Additional metadata #}
                                {% if fandomName or entry.mainPairing or entry.dateFinished %}
                                    <div class="me-fields">
                                        {% if fandomName %}
                                            <div class="me-field">
                                                <span class="me-field-value">{{ fandomName }}</span>
                                            </div>
                                        {% endif %}
                                        {% if entry.mainPairing %}
                                            <div class="me-field">
                                                <i class="bi bi-heart" aria-hidden="true" style="color: #e05c7a;"></i>
                                                <span class="me-field-value">{{ entry.mainPairing.name }}</span>
                                            </div>
                                        {% endif %}
                                        {% if entry.dateFinished %}
                                            <div class="me-field">
                                                <i class="bi bi-calendar3" aria-hidden="true"></i>
                                                <span class="me-field-value">{{ entry.dateFinished|date }}</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                {# Comment — always last #}
                                {% if entry.comments %}
                                    <div class="me-comment">{{ entry.comments }}</div>
                                {% endif %}
                            </div>

                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if total_pages > 1 %}
        <nav aria-label="{{ 'entry.list.pagination'|trans }}" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {% if page <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_reading_entry_list', filters|merge({page: page - 1})) }}"
                       aria-label="{{ 'pagination.previous'|trans }}">
                        &laquo; {{ 'pagination.previous'|trans }}
                    </a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">{{ page }} / {{ total_pages }}</span>
                </li>
                <li class="page-item {% if page >= total_pages %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_reading_entry_list', filters|merge({page: page + 1})) }}"
                       aria-label="{{ 'pagination.next'|trans }}">
                        {{ 'pagination.next'|trans }} &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}
</form>

{% endif %}{# end entries is not empty #}

{# ── Shared overlays: pin form + delete modals ────────────────────────────── #}
{% include 'reading_entry/_modals.html.twig' %}

{# ── Comment offcanvas — populated by JS from data attributes ─────────────── #}
<div class="offcanvas offcanvas-end comment-offcanvas"
     tabindex="-1"
     id="commentOffcanvas"
     aria-labelledby="commentOffcanvasTitle">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title text-truncate" id="commentOffcanvasTitle"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'action.close'|trans }}"></button>
    </div>
    <div class="offcanvas-body">
        <p id="commentOffcanvasBody" class="comment-offcanvas-text mb-0"></p>
    </div>
</div>

{# ── Filter offcanvas ─────────────────────────────────────────────────────── #}
{% include 'reading_entry/_filter_offcanvas.html.twig' with {
    filters: filters,
    statuses: statuses,
    languages: languages,
    metadataTypes: metadataTypes,
    metadataDropdownValues: metadataDropdownValues
} only %}

<script type="module" src="{{ asset('js/bulk-actions.js') }}"></script>

<script>
// Wire comment offcanvas: populate title and body from the triggering button's data attributes
document.addEventListener('DOMContentLoaded', function () {
    var offcanvas = document.getElementById('commentOffcanvas');
    if (!offcanvas) { return; }
    offcanvas.addEventListener('show.bs.offcanvas', function (event) {
        var button = event.relatedTarget;
        if (!button) { return; }
        document.getElementById('commentOffcanvasTitle').textContent = button.getAttribute('data-comment-title') || '';
        document.getElementById('commentOffcanvasBody').textContent = button.getAttribute('data-comment-body') || '';
    });
});

// Wire single-entry delete modal: set action URL and CSRF token from the triggering button's data attributes
document.addEventListener('DOMContentLoaded', function () {
    var deleteModal = document.getElementById('deleteModal');
    if (!deleteModal) { return; }
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        if (!button) { return; }
        var form = document.getElementById('singleDeleteForm');
        var tokenInput = document.getElementById('singleDeleteToken');
        if (form) { form.action = button.getAttribute('data-delete-url') || ''; }
        if (tokenInput) { tokenInput.value = button.getAttribute('data-csrf-token') || ''; }
    });
});
</script>
{% endblock %}
