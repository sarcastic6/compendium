{% extends 'base.html.twig' %}

{% macro metadataChip(item, sourceType, chipClass) %}
    {% set link = item.getLinkForSource(sourceType)|safe_url %}
    {% if link %}
        <a href="{{ link }}" target="_blank" rel="noopener noreferrer"
           class="chip {{ chipClass }} text-decoration-none">{{ item.name }}</a>
    {% else %}
        <span class="chip {{ chipClass }}">{{ item.name }}</span>
    {% endif %}
{% endmacro %}

{% block title %}{{ work.title }}{% endblock %}

{% block body %}

{# Page header: back link + actions #}
<div class="page-header">
    <div class="page-header-text">
        <a href="{{ path('app_reading_entry_list') }}" class="back-link">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            {{ 'nav.library'|trans }}
        </a>
    </div>
    <div class="page-header-actions">
        {% if work.link and work.sourceType.value != 'Manual' %}
            <form method="post" action="{{ path('app_work_refresh', {id: work.id}) }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_work_' ~ work.id) }}">
                <button type="submit" class="btn btn-secondary btn-sm">
                    <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                    {{ 'work.refresh.button'|trans({'%source%': work.sourceType.value}) }}
                </button>
            </form>
        {% endif %}
        <a href="{{ path('app_reading_entry_new', {workId: work.id}) }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            {{ 'work.action.log_entry'|trans }}
        </a>
    </div>
</div>

<div class="row g-4 g-lg-5">

    {# ── Left column: cover art + badges ── #}
    <div class="col-12 col-md-4 col-lg-3">
        <div class="work-cover-col">

            {# Large typographic cover #}
            <div class="cover cover-lg {{ cover_font_class(work.type.value) }}"
                 style="{{ cover_gradient(work.id) }}"
                 aria-hidden="true">
                <span class="cover-title">{{ work.title }}</span>
            </div>

            {# Type + source badges #}
            <div class="d-flex flex-wrap gap-2 mt-3">
                <span class="chip chip-tag">{{ work.type.value }}</span>
                {% if work.link %}
                    <a href="{{ work.link }}" target="_blank" rel="noopener noreferrer"
                       class="chip chip-tag text-decoration-none">
                        {{ work.sourceType.value }}
                        <i class="bi bi-box-arrow-up-right" style="font-size: 0.65em;" aria-hidden="true"></i>
                    </a>
                {% else %}
                    <span class="chip chip-tag">{{ work.sourceType.value }}</span>
                {% endif %}
            </div>

            {# Series info #}
            {% if work.series %}
                <div class="work-series-info">
                    {% set seriesLink = work.series.getLinkForSource(work.sourceType)|safe_url %}
                    <i class="bi bi-collection me-1" aria-hidden="true"></i>
                    {% if seriesLink %}
                        <a href="{{ seriesLink }}" target="_blank" rel="noopener noreferrer">{{ work.series.name }}</a>
                    {% else %}
                        {{ work.series.name }}
                    {% endif %}
                    {% if work.placeInSeries %}
                        &nbsp;#{{ work.placeInSeries }}
                    {% endif %}
                </div>
            {% endif %}

        </div>
    </div>

    {# ── Right column: metadata ── #}
    <div class="col-12 col-md-8 col-lg-9">

        {# Title + last updated date #}
        <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
            <h1 class="work-detail-title">
                {{ work.title }}
            </h1>
            {% if work.lastUpdatedDate %}
                <span class="work-detail-updated">
                    {{ 'work.show.field.last_updated_date'|trans }}: {{ work.lastUpdatedDate|date }}
                </span>
            {% endif %}
        </div>

        {# Authors #}
        {% if work.authors is not empty %}
            <p class="work-detail-authors mb-0">
                {% for author in work.authors %}
                    {% set authorLink = author.getLinkForSource(work.sourceType)|safe_url %}
                    {% if authorLink %}
                        <a href="{{ authorLink }}" target="_blank" rel="noopener noreferrer">{{ author.name }}</a>
                    {% else %}
                        {{ author.name }}
                    {% endif %}
                    {%- if not loop.last %}, {% endif %}
                {% endfor %}
            </p>
        {% endif %}

        {# Stat boxes #}
        {% if work.words or work.chapters or work.publishedDate or work.language %}
            <div class="work-detail-stats">
                {% if work.words %}
                    <div class="work-stat-box">
                        <span class="work-stat-value">{{ work.words|number_format }}</span>
                        <span class="work-stat-label">{{ 'work.field.words'|trans }}</span>
                    </div>
                {% endif %}
                {% if work.chapters %}
                    <div class="work-stat-box">
                        <span class="work-stat-value">{{ work.chapters }}</span>
                        <span class="work-stat-label">{{ 'work.field.chapters'|trans }}</span>
                    </div>
                {% endif %}
                {% if work.publishedDate %}
                    <div class="work-stat-box">
                        <span class="work-stat-value" title="{{ work.publishedDate|date }}">{{ work.publishedDate|date('Y') }}</span>
                        <span class="work-stat-label">{{ 'work.show.field.published_date'|trans }}</span>
                    </div>
                {% endif %}
                {% if work.language %}
                    <div class="work-stat-box">
                        <span class="work-stat-value">{{ work.language.name }}</span>
                        <span class="work-stat-label">{{ 'work.field.language'|trans }}</span>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {# Summary #}
        {% if work.summary %}
            <div class="work-detail-summary mt-4">{{ work.summary }}</div>
        {% endif %}

        {# Metadata chips, grouped by type #}
        {% set metadataTypeOrder = ['Warning', 'Rating', 'Category', 'Fandom', 'Relationships', 'Character', 'Tag'] %}

        {% set grouped = {} %}
        {% for item in work.metadata %}
            {% set key = item.metadataType.name %}
            {% if key != 'Author' %}
                {% if key not in grouped|keys %}
                    {% set grouped = grouped|merge({(key): []}) %}
                {% endif %}
                {% set grouped = grouped|merge({(key): grouped[key]|merge([item])}) %}
            {% endif %}
        {% endfor %}

        {% if grouped is not empty %}
            <div class="work-detail-metadata mt-4">
                {% for typeName in metadataTypeOrder %}
                    {% if typeName in grouped|keys %}
                        {% set chipClass = typeName == 'Rating' ? 'chip-tag-rating' : (typeName == 'Warning' ? 'chip-tag-warning' : 'chip-tag') %}
                        <div class="work-meta-group">
                            <span class="work-meta-label">{{ typeName }}</span>
                            <div class="work-meta-chips">
                                {% for item in grouped[typeName] %}
                                    {{ _self.metadataChip(item, work.sourceType, chipClass) }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
                {# Any types not in the preferred order #}
                {% for typeName, items in grouped %}
                    {% if typeName not in metadataTypeOrder %}
                        <div class="work-meta-group">
                            <span class="work-meta-label">{{ typeName }}</span>
                            <div class="work-meta-chips">
                                {% for item in items %}
                                    {{ _self.metadataChip(item, work.sourceType, 'chip-tag') }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p class="mt-4" style="color: var(--color-text-muted);">{{ 'work.show.no_metadata'|trans }}</p>
        {% endif %}

    </div>
</div>

{% endblock %}
