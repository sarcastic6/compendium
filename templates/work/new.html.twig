{% extends 'base.html.twig' %}

{% block title %}{{ 'work.new_heading'|trans }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ 'work.new_heading'|trans }}</h1>
    <a href="{{ path('app_work_select') }}" class="btn btn-outline-secondary">
        {{ 'work.select_heading'|trans }}
    </a>
</div>

{{ form_start(form, {'attr': {'novalidate': true}}) }}

<div class="row g-3">
    <div class="col-md-6">
        {{ form_row(form.type) }}
        {{ form_row(form.title) }}
        {{ form_row(form.summary) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.sourceType) }}
        {{ form_row(form.link) }}
        {{ form_row(form.seriesName) }}
        {{ form_widget(form.seriesUrl) }}
        {{ form_row(form.placeInSeries) }}
        {{ form_row(form.language) }}
    </div>
    <div class="col-md-3">
        {{ form_row(form.publishedDate) }}
    </div>
    <div class="col-md-3">
        {{ form_row(form.lastUpdatedDate) }}
    </div>
    <div class="col-md-3">
        {{ form_row(form.words) }}
    </div>
    <div class="col-md-3">
        {{ form_row(form.chapters) }}
    </div>
</div>

<hr>

{# Authors — dedicated section with its own collection #}
<div class="mb-4"
     data-collection-widget
     data-prototype="{{ form_widget(form.authors.vars.prototype)|e('html_attr') }}">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">{{ 'work.field.authors'|trans }}</h2>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-collection-add>
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            {{ 'work.field.add_author'|trans }}
        </button>
    </div>
    <div data-collection-entries>
        {% for authorField in form.authors %}
            <div class="collection-item d-flex gap-2 align-items-start mb-2">
                {{ form_widget(authorField) }}
            </div>
        {% endfor %}
    </div>
</div>
{% do form.authors.setRendered %}

{# Shared prototype source for all metadata sections — hidden, used by metadata-sections.js #}
<div id="metadata-prototype-source"
     data-prototype="{{ form_widget(form.metadata.vars.prototype)|e('html_attr') }}"
     data-index="{{ form.metadata|length }}"
     style="display:none"></div>

{# One section per MetadataType, ordered and created by the admin.
   Adding a new type in the admin panel automatically adds a section here. #}
{% for metadataType in metadataTypes %}
<hr>
<div class="mb-4" data-metadata-section data-metadata-type-id="{{ metadataType.id }}">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">{{ metadataType.name }}</h2>
        <button type="button" class="btn btn-outline-secondary btn-sm metadata-section-add-btn" data-metadata-section-add>
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            {{ 'work.field.add_metadata'|trans({'%type%': metadataType.name}) }}
        </button>
    </div>
    <div data-metadata-section-entries>
        {% for entry in form.metadata %}
            {% if entry.vars.data is not null
                and entry.vars.data.metadataType is defined
                and entry.vars.data.metadataType is not null
                and entry.vars.data.metadataType.id == metadataType.id %}
                <div class="collection-item d-flex gap-2 align-items-start mb-2">
                    {{ form_widget(entry) }}
                </div>
            {% endif %}
        {% endfor %}
    </div>
</div>
{% endfor %}
{% do form.metadata.setRendered %}

<hr>

{{ form_row(form.starred) }}

<div class="d-flex gap-2 mt-3">
    <button type="submit" class="btn btn-primary">{{ 'action.save'|trans }}</button>
    <a href="{{ path('app_reading_entry_list') }}" class="btn btn-outline-secondary">{{ 'action.cancel'|trans }}</a>
</div>

{{ form_end(form) }}
{% endblock %}
