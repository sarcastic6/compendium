{% extends 'base.html.twig' %}

{% block title %}{{ 'work.select_heading'|trans }}{% endblock %}

{% block body %}
<h1 class="h3 mb-4">{{ 'work.select_heading'|trans }}</h1>
<p class="text-muted">{{ 'work.select_prompt'|trans }}</p>

<form method="get" action="{{ path('app_work_select') }}" class="mb-4">
    <div class="input-group">
        <input type="search" name="q" value="{{ query }}"
               class="form-control" placeholder="{{ 'work.select_search_placeholder'|trans }}"
               aria-label="{{ 'work.select_search'|trans }}">
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-search" aria-hidden="true"></i>
            {{ 'work.select_search'|trans }}
        </button>
    </div>
</form>

{% if query is not empty %}
    {% if works is empty %}
        <p class="text-muted">{{ 'work.select_no_results'|trans }} <a href="{{ path('app_work_new') }}">{{ 'work.create_new'|trans }}</a></p>
    {% else %}
        <div class="list-group mb-3">
            {% for work in works %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <a href="{{ path('app_work_show', {id: work.id}) }}" class="fw-bold text-decoration-none">
                                {{ work.title }}
                            </a>
                            {% if work.authors is not empty %}
                                <span class="text-muted ms-2">
                                    {{ 'work.select_author_by'|trans }} {{ work.authors|map(a => a.name)|join(', ') }}
                                </span>
                            {% endif %}
                            {% if work.series %}
                                <div><small class="text-muted">{{ work.series.name }}</small></div>
                            {% endif %}
                        </div>
                        <div class="d-flex align-items-center gap-2 ms-2 flex-shrink-0">
                            <span class="badge bg-secondary">{{ work.type.value }}</span>
                            <a href="{{ path('app_reading_entry_new', {workId: work.id}) }}"
                               class="btn btn-sm btn-primary">
                                {{ 'reading.entry.add'|trans }}
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endif %}

<div class="d-flex align-items-center gap-3 my-4">
    <hr class="flex-grow-1 m-0">
    <span class="text-muted small">{{ 'work.import_separator'|trans }}</span>
    <hr class="flex-grow-1 m-0">
</div>

<form method="post" action="{{ path('app_work_select') }}" class="mb-5">
    <input type="hidden" name="_import_token" value="{{ csrf_token('import_url') }}">
    <label for="import_url" class="form-label">{{ 'import.url_field'|trans }}</label>
    <input type="url" id="import_url" name="import_url"
           class="form-control mb-2"
           placeholder="{{ 'import.url_placeholder'|trans }}"
           autocomplete="off">
    <div class="form-text mb-2">{{ 'import.url_help'|trans }}</div>
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-cloud-download" aria-hidden="true"></i>
        {{ 'import.submit'|trans }}
    </button>
</form>

<a href="{{ path('app_work_new') }}" class="btn btn-outline-secondary">
    <i class="bi bi-plus-lg" aria-hidden="true"></i>
    {{ 'work.create_new'|trans }}
</a>
{% endblock %}
