{% extends 'base.html.twig' %}

{% block title %}{{ 'data.index.heading'|trans }}{% endblock %}

{% block body %}
<div class="page-header">
    <h1 class="page-title">{{ 'data.index.heading'|trans }}</h1>
    <p class="page-subtitle">{{ 'data.index.description'|trans }}</p>
</div>

<section class="mb-5">
    <h2 class="h5 mb-3">{{ 'data.export.section_heading'|trans }}</h2>

    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h3 class="card-title h6">{{ 'data.export.data_dump.label'|trans }}</h3>
                    <p class="card-text text-muted small flex-grow-1">
                        {{ 'data.export.data_dump.description'|trans }}
                    </p>
                    <a href="{{ path('app_data_export_data_dump') }}"
                       class="btn btn-primary btn-sm mt-3 align-self-start">
                        <i class="bi bi-download me-1" aria-hidden="true"></i>
                        {{ 'data.export.data_dump.button'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
