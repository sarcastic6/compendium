{% extends 'base.html.twig' %}

{% block title %}{{ 'import.heading'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'import.heading'|trans }}</h1>
    <p class="text-muted">{{ 'import.url_help'|trans }}</p>

    {{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.url) }}
        {{ form_widget(form.url, {'attr': {'class': 'form-control' ~ (form.url.vars.errors|length ? ' is-invalid' : '')}}) }}
        {{ form_errors(form.url) }}
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">{{ 'import.submit'|trans }}</button>
        <a href="{{ path('app_work_select') }}" class="btn btn-outline-secondary">{{ 'action.cancel'|trans }}</a>
    </div>
    {{ form_end(form) }}
{% endblock %}
