{% extends 'auth_base.html.twig' %}

{% block title %}{{ 'mfa.code_prompt'|trans }}{% endblock %}

{% block body %}
<div class="auth-card">

    <div class="auth-header">
        <div class="auth-app-name">Compendium</div>
        <div class="auth-app-sub">{{ 'mfa.code_prompt'|trans }}</div>
    </div>

    {% if authenticationError %}
        <div class="flash flash-error" role="alert">
            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
            <span class="flash-body">{{ authenticationError.messageKey|trans(authenticationError.messageData, 'security') }}</span>
        </div>
    {% endif %}

    <form method="post" action="{{ path('2fa_login_check') }}" class="auth-form">

        <div>
            <label for="auth_code" class="form-label">{{ 'mfa.code_field'|trans }}</label>
            <input type="text" id="auth_code" name="_auth_code"
                   class="form-control"
                   autocomplete="one-time-code"
                   inputmode="numeric" pattern="[0-9]*"
                   maxlength="6" required autofocus
                   style="font-size: var(--text-xl); letter-spacing: 0.3em; text-align: center;">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa') }}">

        <button type="submit" class="btn btn-primary auth-submit-btn">
            {{ 'action.confirm'|trans }} →
        </button>

    </form>

    <div class="auth-footer">
        <a href="{{ path('app_login') }}">← {{ 'nav.login'|trans }}</a>
    </div>

</div>
{% endblock %}
