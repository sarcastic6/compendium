{% extends 'auth_base.html.twig' %}

{% block title %}{{ 'auth.login.heading'|trans }}{% endblock %}

{% block body %}
<div class="auth-card">

    <div class="auth-header">
        <div class="auth-app-name">Compendium</div>
        <div class="auth-app-sub">{{ 'nav.brand_sub'|trans }}</div>
    </div>

    {% if error %}
        <div class="flash flash-error" role="alert">
            <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
            <span class="flash-body">{{ error.messageKey|trans(error.messageData, 'security') }}</span>
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}" class="auth-form" novalidate>
        <div>
            <label for="username" class="form-label">{{ 'auth.register.email'|trans }}</label>
            <input type="email" id="username" name="_username"
                   class="form-control" value="{{ last_username }}"
                   autocomplete="email" required autofocus>
        </div>

        <div>
            <label for="password" class="form-label">{{ 'auth.register.password'|trans }}</label>
            <input type="password" id="password" name="_password"
                   class="form-control" autocomplete="current-password" required>
        </div>

        <div class="d-flex align-items-center justify-content-between">
            <div class="form-check">
                <input type="checkbox" id="remember_me" name="_remember_me" class="form-check-input">
                <label class="form-check-label" for="remember_me">{{ 'auth.login.remember_me'|trans }}</label>
            </div>
            <a href="{{ path('reset_password_request') }}" style="font-size: var(--text-xs); color: var(--color-text-muted);">
                {{ 'auth.login.forgot_password'|trans }}
            </a>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="btn btn-primary auth-submit-btn">
            {{ 'nav.login'|trans }} →
        </button>
    </form>

    <div class="auth-footer">
        {{ 'auth.login.no_account'|trans }}
        <a href="{{ path('app_register') }}">{{ 'nav.register'|trans }}</a>
    </div>

</div>

<div class="auth-quote">
    <i class="bi bi-book" aria-hidden="true"></i><br>
    "A reader lives a thousand lives before he dies."
</div>
{% endblock %}
