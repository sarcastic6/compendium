{% extends 'base.html.twig' %}

{% block title %}{{ 'mfa.totp.enable'|trans }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body p-4">
                <h1 class="h4 card-title mb-4">{{ 'mfa.totp.enable'|trans }}</h1>

                <p>{{ 'mfa.totp.scan_qr'|trans }}</p>

                <div class="text-center my-3">
                    {{ qr_svg|raw }}
                </div>

                <p class="text-muted small text-center">
                    Manual key: <code>{{ secret }}</code>
                </p>

                <form method="post" action="{{ path('app_mfa_totp_verify') }}" novalidate>
                    <div class="mb-3">
                        <label for="code" class="form-label">{{ 'mfa.totp.verify_code'|trans }}</label>
                        <input type="text" id="code" name="code"
                               class="form-control" autocomplete="one-time-code"
                               inputmode="numeric" pattern="[0-9]*"
                               maxlength="6" required autofocus>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('mfa_totp_verify') }}">
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">{{ 'action.confirm'|trans }}</button>
                    </div>
                </form>

                <div class="mt-3 text-center">
                    <a href="{{ path('app_mfa_setup') }}" class="btn btn-link">{{ 'action.cancel'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
