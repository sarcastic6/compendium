{% extends 'base.html.twig' %}

{% block title %}{{ 'mfa.heading'|trans }}{% endblock %}

{% block body %}
<h1 class="h3 mb-4">{{ 'mfa.heading'|trans }}</h1>

<div class="row g-4">
    {# TOTP #}
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5 card-title">{{ 'mfa.totp.heading'|trans }}</h2>
                {% if totp_enabled %}
                    <p class="text-success"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> {{ 'mfa.status.enabled'|trans }}</p>
                    <form method="post" action="{{ path('app_mfa_totp_disable') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('mfa_totp_disable') }}">
                        <button type="submit" class="btn btn-outline-danger">
                            {{ 'mfa.totp.disable'|trans }}
                        </button>
                    </form>
                {% else %}
                    <p class="text-muted">{{ 'mfa.status.not_enabled'|trans }}</p>
                    <a href="{{ path('app_mfa_totp_enable') }}" class="btn btn-outline-primary">
                        {{ 'mfa.totp.enable'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    {# Email MFA #}
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5 card-title">{{ 'mfa.email.heading'|trans }}</h2>
                {% if email_enabled %}
                    <p class="text-success"><i class="bi bi-check-circle-fill" aria-hidden="true"></i> {{ 'mfa.status.enabled'|trans }}</p>
                    <form method="post" action="{{ path('app_mfa_email_disable') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('mfa_email_disable') }}">
                        <button type="submit" class="btn btn-outline-danger">
                            {{ 'mfa.email.disable'|trans }}
                        </button>
                    </form>
                {% else %}
                    <p class="text-muted">{{ 'mfa.status.not_enabled'|trans }}</p>
                    <form method="post" action="{{ path('app_mfa_email_enable') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('mfa_email_enable') }}">
                        <button type="submit" class="btn btn-outline-primary">
                            {{ 'mfa.email.enable'|trans }}
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">
        {{ 'action.cancel'|trans }}
    </a>
</div>
{% endblock %}
