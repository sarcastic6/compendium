{#
    Shared header partial for all rankings pages.

    Expected variables (passed from the including template's scope):
    - type, year, availableYears, rankingRoute, rankingRouteParams,
      sortColumn, sortDir, rankingTypes
#}

<div class="page-header">
    <div class="page-header-text">
        <a href="{{ path('app_stats_dashboard', {'year': year}) }}" class="back-link">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            {{ 'stats.rankings.back_to_dashboard'|trans }}
        </a>
        <h1 class="page-title mt-2">{{ 'stats.rankings.heading'|trans({'%type%': type}) }}</h1>
    </div>
    <div class="page-header-actions">
        {# Year filter pills — preserve sort/dir across year changes #}
        <div class="year-filter-pills" style="margin-bottom: 0;">
            <a href="{{ path(rankingRoute, rankingRouteParams|merge({'year': null, 'sort': sortColumn, 'dir': sortDir})) }}"
               class="year-pill{% if year is null %} active{% endif %}">
                {{ 'stats.filter.all_time'|trans }}
            </a>
            {% for y in availableYears %}
                <a href="{{ path(rankingRoute, rankingRouteParams|merge({'year': y, 'sort': sortColumn, 'dir': sortDir})) }}"
                   class="year-pill{% if y == year %} active{% endif %}">
                    {{ y }}
                </a>
            {% endfor %}
        </div>
    </div>
</div>

{# Ranking type navigation #}
<div class="year-filter-pills mb-5">
    {% set fixedTypes = [
        {'label': 'stats.rankings.type_status'|trans,       'route': 'app_stats_rankings_status',       'params': {}, 'key': 'Status'},
        {'label': 'stats.rankings.type_language'|trans,     'route': 'app_stats_rankings_language',     'params': {}, 'key': 'Language'},
        {'label': 'stats.rankings.type_main_pairing'|trans, 'route': 'app_stats_rankings_main_pairing', 'params': {}, 'key': 'Main Pairing'},
        {'label': 'stats.rankings.type_author'|trans,       'route': 'app_stats_rankings_author',       'params': {}, 'key': 'Author'},
        {'label': 'stats.rankings.type_series'|trans,       'route': 'app_stats_rankings_series',       'params': {}, 'key': 'Series'},
    ] %}
    {% for item in fixedTypes %}
        <a href="{{ path(item.route, {'year': year}) }}"
           class="year-pill{% if type == item.key %} active{% endif %}">
            {{ item.label }}
        </a>
    {% endfor %}
    {% for typeName in rankingTypes %}
        {% if typeName != 'Author' %}
            <a href="{{ path('app_stats_rankings', {'type': typeName, 'year': year}) }}"
               class="year-pill{% if type == typeName %} active{% endif %}">
                {{ typeName }}
            </a>
        {% endif %}
    {% endfor %}
</div>
