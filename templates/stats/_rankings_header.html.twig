{#
    Shared header partial for all rankings pages.
    Renders the page heading, year filter, back button, and ranking type nav.

    Expected variables (passed from the including template's scope):
    - type:               current ranking type label (e.g. 'Status', 'Fandom', 'Author')
    - year:               currently selected year (int|null)
    - availableYears:     int[] of years with data
    - rankingRoute:       route name for this rankings page (used by year filter form)
    - rankingRouteParams: extra route params for rankingRoute (e.g. {type: 'Fandom'})
    - sortColumn:         currently active sort column (preserved across year changes)
    - sortDir:            currently active sort direction (preserved across year changes)
    - rankingTypes:       string[] of metadata type names with data (for dynamic nav buttons)
#}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0">{{ 'stats.rankings.heading'|trans({'%type%': type}) }}</h1>

    <div class="d-flex align-items-center gap-2">
        {# Year filter — hidden inputs preserve sort/dir across year changes #}
        <form method="get" action="{{ path(rankingRoute, rankingRouteParams) }}" class="d-flex align-items-center gap-2">
            <input type="hidden" name="sort" value="{{ sortColumn }}">
            <input type="hidden" name="dir" value="{{ sortDir }}">
            <label for="year-filter" class="form-label mb-0 text-nowrap small">
                <i class="bi bi-funnel"></i>
            </label>
            <select id="year-filter" name="year" class="form-select form-select-sm" style="width: auto"
                    onchange="this.form.submit()" aria-label="{{ 'stats.filter.all_time'|trans }}">
                <option value="">{{ 'stats.filter.all_time'|trans }}</option>
                {% for y in availableYears %}
                    <option value="{{ y }}"{% if y == year %} selected{% endif %}>
                        {{- 'stats.filter.finished_in'|trans({'%year%': y}) -}}
                    </option>
                {% endfor %}
            </select>
        </form>

        <a href="{{ path('app_stats_dashboard', {'year': year}) }}"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i>
            {{ 'stats.rankings.back_to_dashboard'|trans }}
        </a>
    </div>
</div>

{# ── Ranking type navigation ─────────────────────────────────────────────── #}
<div class="d-flex flex-wrap gap-2 mb-4">
    {% set fixedTypes = [
        {'label': 'stats.rankings.type_status'|trans,       'route': 'app_stats_rankings_status',       'params': {}, 'key': 'Status'},
        {'label': 'stats.rankings.type_language'|trans,     'route': 'app_stats_rankings_language',     'params': {}, 'key': 'Language'},
        {'label': 'stats.rankings.type_main_pairing'|trans, 'route': 'app_stats_rankings_main_pairing', 'params': {}, 'key': 'Main Pairing'},
        {'label': 'stats.rankings.type_author'|trans,       'route': 'app_stats_rankings_author',       'params': {}, 'key': 'Author'},
    ] %}
    {% for item in fixedTypes %}
        <a href="{{ path(item.route, {'year': year}) }}"
           class="btn btn-sm {{ type == item.key ? 'btn-primary' : 'btn-outline-secondary' }}">
            {{ item.label }}
        </a>
    {% endfor %}
    {% for typeName in rankingTypes %}
        {# Author has a dedicated page — skip it here to avoid a duplicate button #}
        {% if typeName != 'Author' %}
            <a href="{{ path('app_stats_rankings', {'type': typeName, 'year': year}) }}"
               class="btn btn-sm {{ type == typeName ? 'btn-primary' : 'btn-outline-secondary' }}">
                {{ typeName }}
            </a>
        {% endif %}
    {% endfor %}
</div>
