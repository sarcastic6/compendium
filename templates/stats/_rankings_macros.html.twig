{#
    Shared macros for rankings pages.
    Import with: {% from 'stats/_rankings_macros.html.twig' import sortHeader %}
#}

{#
    sortHeader — renders a sortable column header link.

    Parameters:
    - col, label, align, extraClass, sortColumn, sortDir,
      rankingRoute, rankingRouteParams, year
#}
{% macro sortHeader(col, label, align, extraClass, sortColumn, sortDir, rankingRoute, rankingRouteParams, year) %}
    {% set isActive = (sortColumn == col) %}
    {% set nextDir = (isActive and sortDir == 'desc') ? 'asc' : 'desc' %}
    <th class="text-{{ align }}{{ extraClass ? ' ' ~ extraClass : '' }}{% if isActive %} th-sort-active{% endif %}">
        <a href="{{ path(rankingRoute, rankingRouteParams|merge({
            'year': year,
            'sort': col,
            'dir': nextDir
        })) }}" class="d-flex flex-column align-items-{{ align == 'end' ? 'end' : 'start' }} text-decoration-none gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
            <span>{{ label }}</span>
            {% if isActive %}
                <i class="bi bi-caret-{{ sortDir == 'asc' ? 'up' : 'down' }}-fill" style="font-size: 0.6em;"></i>
            {% else %}
                <i class="bi bi-chevron-expand opacity-25" style="font-size: 0.6em;"></i>
            {% endif %}
        </a>
    </th>
{% endmacro %}
