{% extends 'base.html.twig' %}

{% from 'stats/_rankings_macros.html.twig' import sortHeader %}

{% block title %}{{ 'stats.rankings.heading'|trans({'%type%': type}) }}{% endblock %}

{% block body %}
{% include 'stats/_rankings_header.html.twig' %}

<div class="card shadow-sm">
    <div class="card-body p-0">
        {% if rankings is empty %}
            <p class="text-muted m-3">{{ 'stats.rankings.empty'|trans }}</p>
        {% else %}
            {# Year-scoped date params for series drill-down links #}
            {% set yearParams = year ? {'dateFrom': year ~ '-01-01', 'dateTo': year ~ '-12-31'} : {} %}

            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            {{ sortHeader('name',       'stats.rankings.col_name'|trans,             'start', '',     sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            <th class="text-end pe-3">{{ 'stats.rankings.col_series_status'|trans }}</th>
                            {{ sortHeader('count',      'stats.rankings.col_count'|trans,            'end',   '',     sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('works_read', 'stats.rankings.col_series_works'|trans,     'end',   '',     sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('words_read', 'stats.rankings.col_series_words'|trans,     'end',   '',     sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('coverage',   'stats.rankings.col_series_coverage'|trans ~ ' *', 'end', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('avg_review', 'stats.rankings.col_avg_review'|trans,       'end',   '',     sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in rankings %}
                            <tr>
                                <td>
                                    {# Internal drill-down: show all reading entries for this series #}
                                    <a href="{{ path('app_reading_entry_list', {'series': item.sid}|merge(yearParams)) }}"
                                       class="text-decoration-none">{{ item.name }}</a>
                                    {% if item.ao3Link %}
                                        <a href="{{ item.ao3Link }}" target="_blank" rel="noopener noreferrer"
                                           class="ms-1 text-muted"
                                           title="{{ 'stats.rankings.series_ao3_link'|trans }}">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    {% endif %}
                                </td>
                                <td class="text-end pe-3">
                                    {% if item.isComplete is same as(true) %}
                                        <span class="badge text-bg-success">{{ 'stats.rankings.series_complete'|trans }}</span>
                                    {% elseif item.isComplete is same as(false) %}
                                        <span class="badge text-bg-secondary">{{ 'stats.rankings.series_ongoing'|trans }}</span>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">{{ item.count }}</td>
                                <td class="text-end">
                                    {{ item.worksRead }}
                                    {% if item.totalWorks is not null %}
                                        <span class="text-muted"> / {{ item.totalWorks }}</span>
                                        {% set worksPct = item.totalWorks > 0 ? ((item.worksRead / item.totalWorks) * 100)|round : 0 %}
                                        {% if worksPct <= 100 %}
                                            <div class="progress mt-1 ms-auto" style="height: 3px; width: 80px;">
                                                <div class="progress-bar" role="progressbar"
                                                     style="width: {{ worksPct }}%"
                                                     aria-valuenow="{{ worksPct }}" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                        {% endif %}
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {{ item.wordsRead > 0 ? item.wordsRead|number_format(0, '.', ',') : '—' }}
                                </td>
                                <td class="text-end">
                                    {{ item.coverageWords > 0 ? item.coverageWords|number_format(0, '.', ',') : '—' }}
                                    {% if item.totalWords is not null and item.totalWords > 0 %}
                                        <span class="text-muted"> / {{ item.totalWords|number_format(0, '.', ',') }}</span>
                                        {% set coveragePct = ((item.coverageWords / item.totalWords) * 100)|round %}
                                        {% if coveragePct <= 100 %}
                                            <div class="progress mt-1 ms-auto" style="height: 3px; width: 80px;">
                                                <div class="progress-bar" role="progressbar"
                                                     style="width: {{ coveragePct }}%"
                                                     aria-valuenow="{{ coveragePct }}" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>
                                        {% endif %}
                                    {% endif %}
                                </td>
                                {% if item.avgReview is not null %}
                                    {% if item.avgReview <= 2.5 %}
                                        {% set reviewHue = ((item.avgReview - 1) / 1.5 * 60)|round %}
                                    {% else %}
                                        {% set reviewHue = (60 + (item.avgReview - 2.5) / 2.5 * 60)|round %}
                                    {% endif %}
                                    <td class="text-end" style="background-color: hsl({{ reviewHue }}, 70%, 85%)">{{ item.avgReview }}</td>
                                {% else %}
                                    <td class="text-end">—</td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

<p class="text-muted mt-2" style="font-size: 0.85rem;">{{ 'stats.rankings.series_coverage_note'|trans }}</p>
{% endblock %}
