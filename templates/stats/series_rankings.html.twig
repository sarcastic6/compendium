{% extends 'base.html.twig' %}

{% from 'stats/_rankings_macros.html.twig' import sortHeader %}

{% block title %}{{ 'stats.rankings.heading'|trans({'%type%': type}) }}{% endblock %}

{% block body %}
{% include 'stats/_rankings_header.html.twig' %}

<div class="chart-card">
    {% if rankings is empty %}
        <div class="chart-card-body">
            <p class="empty-state-text">{{ 'stats.rankings.empty'|trans }}</p>
        </div>
    {% else %}
        {% set yearParams = year ? {'dateFrom': year ~ '-01-01', 'dateTo': year ~ '-12-31'} : {} %}
        <div class="table-responsive">
            <table class="data-table align-middle">
                <thead>
                    <tr>
                        {{ sortHeader('name',       'stats.rankings.col_name'|trans,                 'start', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        <th>{{ 'stats.rankings.col_series_status'|trans }}</th>
                        {{ sortHeader('count',      'stats.rankings.col_count'|trans,                'end',   '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('works_read', 'stats.rankings.col_series_works'|trans,         'end',   '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('words_read', 'stats.rankings.col_series_words'|trans,         'end',   '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('coverage',   'stats.rankings.col_series_coverage'|trans ~ ' *', 'end', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('avg_review', 'stats.rankings.col_avg_review'|trans,           'end',   '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                    </tr>
                </thead>
                <tbody>
                    {% for item in rankings %}
                        <tr>
                            <td>
                                <div class="rank-name-cell">
                                    <div class="rank-avatar" style="{{ cover_gradient(item.name|length) }}">
                                        {{ item.name|first|upper }}
                                    </div>
                                    <div class="rank-name-text">
                                        <a href="{{ path('app_reading_entry_list', {'series': item.sid}|merge(yearParams)) }}"
                                           class="rank-name-primary text-decoration-none">{{ item.name }}</a>
                                        {% if item.ao3Link %}
                                            <a href="{{ item.ao3Link }}" target="_blank" rel="noopener noreferrer"
                                               class="ms-1" style="color: var(--color-text-faint); font-size: var(--text-xs);"
                                               title="{{ 'stats.rankings.series_ao3_link'|trans }}">
                                                <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% if item.isComplete is same as(true) %}
                                    <span class="chip chip-tag" style="background: var(--color-tertiary); color: var(--color-primary);">{{ 'stats.rankings.series_complete'|trans }}</span>
                                {% elseif item.isComplete is same as(false) %}
                                    <span class="chip chip-tag">{{ 'stats.rankings.series_ongoing'|trans }}</span>
                                {% else %}
                                    <span style="color: var(--color-text-faint)">—</span>
                                {% endif %}
                            </td>
                            <td class="text-end tabular-nums">{{ item.count }}</td>
                            <td class="text-end tabular-nums">
                                {{ item.worksRead }}
                                {% if item.totalWorks is not null %}
                                    <span style="color: var(--color-text-muted)"> / {{ item.totalWorks }}</span>
                                    {% set worksPct = item.totalWorks > 0 ? ((item.worksRead / item.totalWorks) * 100)|round : 0 %}
                                    {% if worksPct <= 100 %}
                                        <div class="series-progress-bar" style="width: 80px;">
                                            <div class="series-progress-fill" style="width: {{ worksPct }}%;"></div>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </td>
                            <td class="text-end tabular-nums">
                                {{ item.wordsRead > 0 ? item.wordsRead|number_format(0, '.', ',') : '—' }}
                            </td>
                            <td class="text-end tabular-nums">
                                {{ item.coverageWords > 0 ? item.coverageWords|number_format(0, '.', ',') : '—' }}
                                {% if item.totalWords is not null and item.totalWords > 0 %}
                                    <span style="color: var(--color-text-muted)"> / {{ item.totalWords|number_format(0, '.', ',') }}</span>
                                    {% set coveragePct = ((item.coverageWords / item.totalWords) * 100)|round %}
                                    {% if coveragePct <= 100 %}
                                        <div class="series-progress-bar" style="width: 80px;">
                                            <div class="series-progress-fill" style="width: {{ coveragePct }}%;"></div>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </td>
                            {% if item.avgReview is not null %}
                                {% set reviewHue = item.avgReview <= 2.5 ? ((item.avgReview - 1) / 1.5 * 60)|round : (60 + (item.avgReview - 2.5) / 2.5 * 60)|round %}
                                <td class="text-end">
                                    <span class="avg-review-display" style="background: hsl({{ reviewHue }}, 55%, 88%); color: hsl({{ reviewHue }}, 55%, 30%)">{{ item.avgReview }}</span>
                                </td>
                            {% else %}
                                <td class="text-end" style="color: var(--color-text-faint)">—</td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>

<p class="rankings-footnote">{{ 'stats.rankings.series_coverage_note'|trans }}</p>
{% endblock %}
