{% extends 'base.html.twig' %}

{% from 'stats/_rankings_macros.html.twig' import sortHeader %}

{% block title %}{{ 'stats.rankings.heading'|trans({'%type%': type}) }}{% endblock %}

{% block body %}
{% include 'stats/_rankings_header.html.twig' %}

<div class="chart-card">
    {% if rankings is empty %}
        <div class="chart-card-body">
            <p class="empty-state-text">{{ 'stats.rankings.empty'|trans }}</p>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="data-table rankings-table">
                <thead>
                    <tr>
                        {{ sortHeader('name',      'stats.rankings.col_name'|trans,      'start', '',      sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('count',     'stats.rankings.col_count'|trans,     'end',   '',      sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('count_pct', 'stats.rankings.col_count_pct'|trans, 'end',   '',      sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('words',     'stats.rankings.col_words'|trans,     'end',   '',      sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {{ sortHeader('words_pct', 'stats.rankings.col_words_pct'|trans, 'end',   '',      sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {% if showReadColumns %}
                            {{ sortHeader('read_count', 'stats.rankings.col_read_count'|trans, 'end', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('read_pct',   'stats.rankings.col_read_pct'|trans,   'end', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {% endif %}
                        {% if showAvgReview %}
                            {{ sortHeader('avg_review',   'stats.rankings.col_avg_review'|trans,   'end', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {% endif %}
                        {% if showAbandonRate %}
                            {{ sortHeader('abandon_rate', 'stats.rankings.col_abandon_rate'|trans, 'end', '', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% set yearParams = year ? {'dateFrom': year ~ '-01-01', 'dateTo': year ~ '-12-31'} : {} %}
                    {% for item in rankings %}
                        {% if type == 'Status' %}
                            {% set drillUrl = path('app_reading_entry_list', {'statusName': item.name}|merge(yearParams)) %}
                        {% elseif type == 'Language' %}
                            {% set drillUrl = path('app_reading_entry_list', {'language': item.name}|merge(yearParams)) %}
                        {% elseif type == 'Main Pairing' %}
                            {% set drillUrl = path('app_reading_entry_list', {'mainPairing': item.name}|merge(yearParams)) %}
                        {% else %}
                            {% set drillUrl = path('app_reading_entry_list', {'metadata': {(type): item.name}}|merge(yearParams)) %}
                        {% endif %}
                        <tr>
                            <td>
                                <div class="rank-name-cell">
                                    <div class="rank-avatar" style="{{ cover_gradient(item.name|length) }}">
                                        {{ item.name|first|upper }}
                                    </div>
                                    <div class="rank-name-text">
                                        <a href="{{ drillUrl }}" class="rank-name-primary text-decoration-none">{{ item.name }}</a>
                                    </div>
                                </div>
                            </td>
                            <td class="text-end tabular-nums">{{ item.count }}</td>
                            <td class="text-end tabular-nums" style="color: var(--color-text-muted)">{{ item.countPct }}%</td>
                            <td class="text-end tabular-nums">{{ item.totalWords|number_format(0, '.', ',') }}</td>
                            <td class="text-end tabular-nums" style="color: var(--color-text-muted)">{{ item.wordsPct }}%</td>
                            {% if showReadColumns %}
                                <td class="text-end tabular-nums">{{ item.readCount }}</td>
                                <td class="text-end tabular-nums" style="color: var(--color-text-muted)">{{ item.readPct }}%</td>
                            {% endif %}
                            {% if showAvgReview %}
                                {% if item.avgReview is not null %}
                                    {% set reviewHue = item.avgReview <= 2.5 ? ((item.avgReview - 1) / 1.5 * 60)|round : (60 + (item.avgReview - 2.5) / 2.5 * 60)|round %}
                                    <td class="text-end">
                                        <span class="avg-review-display" style="background: hsl({{ reviewHue }}, 55%, 88%); color: hsl({{ reviewHue }}, 55%, 30%)">{{ item.avgReview }}</span>
                                    </td>
                                {% else %}
                                    <td class="text-end" style="color: var(--color-text-faint)">—</td>
                                {% endif %}
                            {% endif %}
                            {% if showAbandonRate %}
                                {% if item.abandonRate is not null %}
                                    {% set abandonHue = ((100 - item.abandonRate) / 100 * 120)|round %}
                                    <td class="text-end">
                                        <span class="finish-rate-badge" style="background: hsl({{ abandonHue }}, 55%, 88%); color: hsl({{ abandonHue }}, 55%, 30%)">{{ item.abandonRate }}%</span>
                                    </td>
                                {% else %}
                                    <td class="text-end" style="color: var(--color-text-faint)">—</td>
                                {% endif %}
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
