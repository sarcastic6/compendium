{% extends 'base.html.twig' %}

{% from 'stats/_rankings_macros.html.twig' import sortHeader %}

{% block title %}{{ 'stats.rankings.heading'|trans({'%type%': type}) }}{% endblock %}

{% block body %}
{% include 'stats/_rankings_header.html.twig' %}

<div class="card shadow-sm">
    <div class="card-body p-0">
        {% if rankings is empty %}
            <p class="text-muted m-3">{{ 'stats.rankings.empty'|trans }}</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            {{ sortHeader('name',      'stats.rankings.col_name'|trans,      'start', '',                                                    sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('count',     'stats.rankings.col_count'|trans,     'end',   '',                                                    sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('count_pct', 'stats.rankings.col_count_pct'|trans, 'end',   '',                                                    sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('words',     'stats.rankings.col_words'|trans,     'end',   '',                                                    sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ sortHeader('words_pct', 'stats.rankings.col_words_pct'|trans, 'end',   showReadColumns or showAvgReview ? '' : 'pe-3',        sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {% if showReadColumns %}
                                {{ sortHeader('read_count', 'stats.rankings.col_read_count'|trans, 'end', '',                         sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                                {{ sortHeader('read_pct',   'stats.rankings.col_read_pct'|trans,   'end', showAvgReview ? '' : 'pe-3', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {% endif %}
                            {% if showAvgReview %}
                                {{ sortHeader('avg_review', 'stats.rankings.col_avg_review'|trans, 'end', 'pe-3', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {# Year-scoped date params passed through to the reading entry list filter. #}
                        {% set yearParams = year ? {'dateFrom': year ~ '-01-01', 'dateTo': year ~ '-12-31'} : {} %}
                        {% for item in rankings %}
                            {# Build drill-down URL based on the current ranking type. #}
                            {% if type == 'Status' %}
                                {% set drillUrl = path('app_reading_entry_list', {'statusName': item.name}|merge(yearParams)) %}
                            {% elseif type == 'Language' %}
                                {% set drillUrl = path('app_reading_entry_list', {'language': item.name}|merge(yearParams)) %}
                            {% elseif type == 'Main Pairing' %}
                                {% set drillUrl = path('app_reading_entry_list', {'mainPairing': item.name}|merge(yearParams)) %}
                            {% else %}
                                {# Metadata type (Fandom, Character, Pairing/Relationships, Tag, etc.) #}
                                {% set drillUrl = path('app_reading_entry_list', {'metadata': {(type): item.name}}|merge(yearParams)) %}
                            {% endif %}
                            <tr>
                                <td><a href="{{ drillUrl }}" class="text-decoration-none">{{ item.name }}</a></td>
                                <td class="text-end">{{ item.count }}</td>
                                <td class="text-end text-muted">{{ item.countPct }}%</td>
                                <td class="text-end">{{ item.totalWords|number_format(0, '.', ',') }}</td>
                                <td class="text-end text-muted {{ showReadColumns or showAvgReview ? '' : 'pe-3' }}">{{ item.wordsPct }}%</td>
                                {% if showReadColumns %}
                                    <td class="text-end">{{ item.readCount }}</td>
                                    <td class="text-end text-muted {{ showAvgReview ? '' : 'pe-3' }}">{{ item.readPct }}%</td>
                                {% endif %}
                                {% if showAvgReview %}
                                    {% if item.avgReview is not null %}
                                        {% if item.avgReview <= 2.5 %}
                                            {% set reviewHue = ((item.avgReview - 1) / 1.5 * 60)|round %}
                                        {% else %}
                                            {% set reviewHue = (60 + (item.avgReview - 2.5) / 2.5 * 60)|round %}
                                        {% endif %}
                                        <td class="text-end pe-3" style="background-color: hsl({{ reviewHue }}, 70%, 85%)">{{ item.avgReview }}</td>
                                    {% else %}
                                        <td class="text-end pe-3">—</td>
                                    {% endif %}
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
