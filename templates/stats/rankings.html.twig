{% extends 'base.html.twig' %}

{% block title %}{{ 'stats.rankings.heading'|trans({'%type%': type}) }}{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h1 class="h3 mb-0">{{ 'stats.rankings.heading'|trans({'%type%': type}) }}</h1>

    <div class="d-flex align-items-center gap-2">
        {# Year filter — hidden inputs preserve sort/dir across year changes #}
        <form method="get" action="{{ path(rankingRoute, rankingRouteParams) }}" class="d-flex align-items-center gap-2">
            <input type="hidden" name="sort" value="{{ sortColumn }}">
            <input type="hidden" name="dir" value="{{ sortDir }}">
            <label for="year-filter" class="form-label mb-0 text-nowrap small">
                <i class="bi bi-funnel"></i>
            </label>
            <select id="year-filter" name="year" class="form-select form-select-sm" style="width: auto"
                    onchange="this.form.submit()" aria-label="{{ 'stats.filter.all_time'|trans }}">
                <option value="">{{ 'stats.filter.all_time'|trans }}</option>
                {% for y in availableYears %}
                    <option value="{{ y }}"{% if y == year %} selected{% endif %}>
                        {{- 'stats.filter.finished_in'|trans({'%year%': y}) -}}
                    </option>
                {% endfor %}
            </select>
        </form>

        <a href="{{ path('app_stats_dashboard', {'year': year}) }}"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i>
            {{ 'stats.rankings.back_to_dashboard'|trans }}
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        {% if rankings is empty %}
            <p class="text-muted m-3">{{ 'stats.rankings.empty'|trans }}</p>
        {% else %}
            {#
                Helper macro: renders a sortable column header link.
                - col:        the sort key for this column
                - label:      translated label string
                - align:      'start' or 'end' (Bootstrap text-align utility suffix)
                - extraClass: optional extra classes on the <th>
            #}
            {% macro sortHeader(col, label, align, extraClass, sortColumn, sortDir, rankingRoute, rankingRouteParams, year) %}
                {% set isActive = (sortColumn == col) %}
                {% set nextDir = (isActive and sortDir == 'desc') ? 'asc' : 'desc' %}
                <th class="text-{{ align }}{{ extraClass ? ' ' ~ extraClass : '' }}{{ isActive ? ' table-primary' : '' }}">
                    <a href="{{ path(rankingRoute, rankingRouteParams|merge({
                        'year': year,
                        'sort': col,
                        'dir': nextDir
                    })) }}" class="text-decoration-none {{ isActive ? 'fw-semibold' : 'text-muted' }}">
                        {{ label }}
                        {% if isActive %}
                            <i class="bi bi-caret-{{ sortDir == 'asc' ? 'up' : 'down' }}-fill ms-1"></i>
                        {% else %}
                            <i class="bi bi-chevron-expand ms-1 opacity-25"></i>
                        {% endif %}
                    </a>
                </th>
            {% endmacro %}

            {% import _self as self %}

            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width: 3rem">{{ 'stats.rankings.col_rank'|trans }}</th>
                            {{ self.sortHeader('name',      'stats.rankings.col_name'|trans,       'start', '',                              sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ self.sortHeader('count',     'stats.rankings.col_count'|trans,      'end',   '',                              sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ self.sortHeader('count_pct', 'stats.rankings.col_count_pct'|trans,  'end',   '',                              sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ self.sortHeader('words',     'stats.rankings.col_words'|trans,      'end',   '',                              sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {{ self.sortHeader('words_pct', 'stats.rankings.col_words_pct'|trans,  'end',   showReadColumns ? '' : 'pe-3',   sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {% if showReadColumns %}
                                {{ self.sortHeader('read_count','stats.rankings.col_read_count'|trans, 'end', '',     sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                                {{ self.sortHeader('read_pct',  'stats.rankings.col_read_pct'|trans,   'end', 'pe-3', sortColumn, sortDir, rankingRoute, rankingRouteParams, year) }}
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in rankings %}
                            <tr>
                                <td class="ps-3 text-muted">{{ loop.index }}</td>
                                <td>{{ item.name }}</td>
                                <td class="text-end">{{ item.count }}</td>
                                <td class="text-end text-muted">{{ item.countPct }}%</td>
                                <td class="text-end">{{ item.totalWords|number_format(0, '.', ',') }}</td>
                                <td class="text-end text-muted {{ showReadColumns ? '' : 'pe-3' }}">{{ item.wordsPct }}%</td>
                                {% if showReadColumns %}
                                    <td class="text-end">{{ item.readCount }}</td>
                                    <td class="text-end pe-3 text-muted">{{ item.readPct }}%</td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
