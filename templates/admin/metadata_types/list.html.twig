{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.metadata_types.heading'|trans }}{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-header-text">
        <a href="{{ path('app_admin_index') }}" class="back-link">← {{ 'nav.admin'|trans }}</a>
        <h1 class="page-title">{{ 'admin.metadata_types.heading'|trans }}</h1>
    </div>
    <div class="page-header-actions">
        <a href="{{ path('app_admin_metadata_type_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            {{ 'action.add'|trans }}
        </a>
    </div>
</div>

{% if metadata_types is empty %}
    <div class="empty-state">
        <i class="bi bi-tags" style="font-size: 2.5rem; color: var(--color-text-faint);" aria-hidden="true"></i>
        <p class="empty-state-text">{{ 'admin.metadata_types.empty'|trans }}</p>
    </div>
{% else %}
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>{{ 'admin.metadata_types.field.name'|trans }}</th>
                    <th>{{ 'admin.metadata_types.field.multiple_allowed'|trans }}</th>
                    <th>{{ 'admin.metadata_types.field.show_as_dropdown'|trans }}</th>
                    <th>{{ 'admin.metadata_types.field.show_as_checkboxes'|trans }}</th>
                    <th class="actions-col"></th>
                </tr>
            </thead>
            <tbody>
                {% for type in metadata_types %}
                    <tr>
                        <td style="font-weight: var(--weight-medium); color: var(--color-text-body);">
                            {{ type.name }}
                        </td>
                        <td>
                            {% if type.multipleAllowed %}
                                <span class="chip chip-tag" style="background: var(--color-tertiary); color: var(--color-primary);">
                                    <i class="bi bi-check-lg" aria-hidden="true"></i> {{ 'action.yes'|trans }}
                                </span>
                            {% else %}
                                <span class="chip chip-tag" style="background: #fce8e8; color: #8b2020; border-color: #f4c0c0;">
                                    <i class="bi bi-x-lg" aria-hidden="true"></i> {{ 'action.no'|trans }}
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if type.showAsDropdown %}
                                <span class="chip chip-tag" style="background: var(--color-tertiary); color: var(--color-primary);">
                                    <i class="bi bi-check-lg" aria-hidden="true"></i> {{ 'action.yes'|trans }}
                                </span>
                            {% else %}
                                <span class="chip chip-tag" style="background: #fce8e8; color: #8b2020; border-color: #f4c0c0;">
                                    <i class="bi bi-x-lg" aria-hidden="true"></i> {{ 'action.no'|trans }}
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if type.showAsCheckboxes %}
                                <span class="chip chip-tag" style="background: var(--color-tertiary); color: var(--color-primary);">
                                    <i class="bi bi-check-lg" aria-hidden="true"></i> {{ 'action.yes'|trans }}
                                </span>
                            {% else %}
                                <span class="chip chip-tag" style="background: #fce8e8; color: #8b2020; border-color: #f4c0c0;">
                                    <i class="bi bi-x-lg" aria-hidden="true"></i> {{ 'action.no'|trans }}
                                </span>
                            {% endif %}
                        </td>
                        <td class="actions-col">
                            <a href="{{ path('app_admin_metadata_type_edit', {id: type.id}) }}"
                               class="btn btn-sm btn-ghost">
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                            </a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
