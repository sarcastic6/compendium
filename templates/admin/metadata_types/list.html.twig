{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.metadata_types.heading'|trans }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ 'admin.metadata_types.heading'|trans }}</h1>
    <a href="{{ path('app_admin_metadata_type_new') }}" class="btn btn-primary">
        <i class="fa-solid fa-plus" aria-hidden="true"></i>
        {{ 'action.add'|trans }}
    </a>
</div>

{% if metadata_types is empty %}
    <p class="text-muted">No metadata types created yet.</p>
{% else %}
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">{{ 'admin.metadata_types.field.name'|trans }}</th>
                    <th scope="col">{{ 'admin.metadata_types.field.multiple_allowed'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for type in metadata_types %}
                    <tr>
                        <td>{{ type.name }}</td>
                        <td>
                            {% if type.multipleAllowed %}
                                <span class="badge bg-success">Yes</span>
                            {% else %}
                                <span class="badge bg-secondary">No</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}

<a href="{{ path('app_admin_index') }}" class="btn btn-outline-secondary mt-3">
    &larr; {{ 'nav.admin'|trans }}
</a>
{% endblock %}
